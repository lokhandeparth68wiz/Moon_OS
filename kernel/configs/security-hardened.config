# Moon OS Security-Hardened Kernel Configuration
# Based on Linux 6.12.x with maximum security hardening

# ============================================================================
# General Security Options
# ============================================================================
CONFIG_SECURITY=y
CONFIG_SECURITY_NETWORK=y
CONFIG_SECURITY_NETWORK_XFRM=y
CONFIG_SECURITY_PATH=y
CONFIG_INOTIFY=y
CONFIG_INOTIFY_USER=y
CONFIG_SECURITY_FILE_PERMISSIONS=y
CONFIG_SECURITY_NETWORK=y
CONFIG_SECURITY_NETWORK_XFRM=y
CONFIG_SECURITY_PATH=y
CONFIG_INOTIFY=y
CONFIG_INOTIFY_USER=y
CONFIG_SECURITY_FILE_PERMISSIONS=y

# ============================================================================
# SELinux Support
# ============================================================================
CONFIG_SECURITY_SELINUX=y
CONFIG_SECURITY_SELINUX_BOOTPARAM=y
CONFIG_SECURITY_SELINUX_DISABLE=y
CONFIG_SECURITY_SELINUX_DEVELOP=y
CONFIG_SECURITY_SELINUX_AVC_STATS=y
CONFIG_SECURITY_SELINUX_CHECKREQPROT_VALUE=0
CONFIG_SECURITY_SELINUX_SIDTAB_HASH_SIZE=128
CONFIG_SECURITY_SELINUX_SID2STR_CACHE_SIZE=256
CONFIG_DEFAULT_SECURITY_SELINUX=y
CONFIG_SECURITY_SELINUX_COMPAT_V2=y

# ============================================================================
# AppArmor Support
# ============================================================================
CONFIG_SECURITY_APPARMOR=y
CONFIG_SECURITY_APPARMOR_BOOTPARAM_VALUE=1
CONFIG_SECURITY_APPARMOR_HASH=y
CONFIG_SECURITY_APPARMOR_HASH_DEFAULT=y

# ============================================================================
# Integrity Measurement Architecture (IMA)
# ============================================================================
CONFIG_IMA=y
CONFIG_IMA_MEASURE_PCR_LEN=10
CONFIG_IMA_APPRAISE=y
CONFIG_IMA_APPRAISE_BOOTPARAM=y
CONFIG_IMA_APPRAISE_SIG=y
CONFIG_IMA_APPRAISE_SIGFORCE=y
CONFIG_IMA_TRUSTED_KEYRING=y
CONFIG_IMA_LOAD_KEYRING=y
CONFIG_IMA_READ_POLICY=y
CONFIG_IMA_DEFAULT_HASH="sha256"
CONFIG_IMA_DEFAULT_TEMPLATE="ima-sig"
CONFIG_IMA_APPRAISE_MODULES=y

# ============================================================================
# Extended Verification Module (EVM)
# ============================================================================
CONFIG_EVM=y
CONFIG_EVM_HMAC_VERSION=2
CONFIG_EVM_ATTR_SECURITY_GPIO=y
CONFIG_EVM_EXTRA_SMACK_LABELS=y

# ============================================================================
# Kernel Lockdown
# ============================================================================
CONFIG_SECURITY_LOCKDOWN_LSM=y
CONFIG_SECURITY_LOCKDOWN_LSM_EARLY=y
CONFIG_SECURITY_LOCKDOWN_LSM_INTEGRITY=y
CONFIG_SECURITY_LOCKDOWN_LSM_CONFIDENTIALITY=y

# ============================================================================
# Kernel Self Protection
# ============================================================================
CONFIG hardened=y
CONFIG_CC_STACKPROTECTOR=y
CONFIG_CC_STACKPROTECTOR_STRONG=y
CONFIG_STACKPROTECTOR_PER_TASK=y
CONFIG_INIT_STACK_ALL_ZERO=y
CONFIG_INIT_STACK_ALL_PATTERN=y
CONFIG_INIT_STACK_ALL_BUILTIN=y
CONFIG_FORTIFY_SOURCE=y
CONFIG_INIT_ON_ALLOC_DEFAULT_ON=y
CONFIG_INIT_ON_FREE_DEFAULT_ON=y
CONFIG_GCC_PLUGIN_STACKLEAK=y
CONFIG_GCC_PLUGIN_STRUCTLEAK=y
CONFIG_GCC_PLUGIN_STRUCTLEAK_BYREF=y
CONFIG_GCC_PLUGIN_STRUCTLEAK_BYREF_ALL=y
CONFIG_GCC_PLUGIN_STRUCTLEAK_VERBOSE=y
CONFIG_GCC_PLUGIN_RANDSTRUCT=y
CONFIG_GCC_PLUGIN_LATENT_ENTROPY=y
CONFIG_GCC_PLUGIN_STRUCTLEAK=y
CONFIG_GCC_PLUGIN_RANDSTRUCT=y
CONFIG_GCC_PLUGIN_LATENT_ENTROPY=y

# ============================================================================
# Address Space Layout Randomization (ASLR)
# ============================================================================
CONFIG_RANDOMIZE_BASE=y
CONFIG_RANDOMIZE_MEMORY=y
CONFIG_RANDOMIZE_MODULE_REGION_FULL=y
CONFIG_RANDOMIZE_MODULE_REGION_ONLY=y
CONFIG_RANDOMIZE_KSTACK_OFFSET_DEFAULT=y

# ============================================================================
# Stack Protection
# ============================================================================
CONFIG_STACKPROTECTOR=y
CONFIG_STACKPROTECTOR_STRONG=y
CONFIG_STACKPROTECTOR_PER_TASK=y
CONFIG_INIT_STACK_ALL_ZERO=y
CONFIG_INIT_STACK_ALL_PATTERN=y
CONFIG_INIT_STACK_ALL_BUILTIN=y
CONFIG_FORTIFY_SOURCE=y
CONFIG_INIT_ON_ALLOC_DEFAULT_ON=y
CONFIG_INIT_ON_FREE_DEFAULT_ON=y

# ============================================================================
# Heap Protection
# ============================================================================
CONFIG_SLAB_FREELIST_RANDOM=y
CONFIG_SLAB_FREELIST_HARDENED=y
CONFIG_SHUFFLE_PAGE_ALLOCATOR=y
CONFIG_SLAB_MERGE_DEFAULT=y
CONFIG_SLUB_DEBUG=y
CONFIG_SLUB_DEBUG_ON=y
CONFIG_SLUB_RCU_DELAY=y
CONFIG_SHUFFLE_PAGE_ALLOCATOR=y

# ============================================================================
# Module Protection
# ============================================================================
CONFIG_MODULES=y
CONFIG_MODULE_UNLOAD=y
CONFIG_MODULE_FORCE_UNLOAD=y
CONFIG_MODULE_SIG=y
CONFIG_MODULE_SIG_SHA256=y
CONFIG_MODULE_SIG_ALL=y
CONFIG_MODULE_SIG_FORCE=y
CONFIG_MODULE_SIG_KEY="certs/signing_key.pem"
CONFIG_MODULE_COMPRESS=y
CONFIG_MODULE_COMPRESS_XZ=y

# ============================================================================
# Kernel Integrity
# ============================================================================
CONFIG_MODULE_SIG=y
CONFIG_MODULE_SIG_SHA256=y
CONFIG_MODULE_SIG_ALL=y
CONFIG_MODULE_SIG_FORCE=y
CONFIG_MODULE_SIG_KEY="certs/signing_key.pem"
CONFIG_MODULE_SIG_HASH="sha256"

# ============================================================================
# KASAN (Kernel Address Sanitizer) - Debugging
# ============================================================================
CONFIG_KASAN=y
CONFIG_KASAN_INLINE=y
CONFIG_KASAN_GENERIC=y
CONFIG_KASAN_OUTLINE=y
CONFIG_KASAN_STACK=1
CONFIG_KASAN_VMALLOC=y
CONFIG_KASAN_GENERIC=y
CONFIG_KASAN_OUTLINE=y
CONFIG_KASAN_INLINE=y
CONFIG_KASAN_STACK=1
CONFIG_KASAN_VMALLOC=y

# ============================================================================
# Kernel Concurrency Sanitizer (KCSAN)
# ============================================================================
CONFIG_KCSAN=y
CONFIG_KCSAN_STRICT=y
CONFIG_KCSAN_ASSUME_BUS_STRICT=y

# ============================================================================
# Random Number Generation
# ============================================================================
CONFIG_CRYPTO_AES_NI_INTEL=y
CONFIG_CRYPTO_AES_X86_64=y
CONFIG_CRYPTO_SHA256_SSSE3=y
CONFIG_CRYPTO_SHA512_SSSE3=y
CONFIG_CRYPTO_AES_NI_INTEL=y
CONFIG_CRYPTO_AES_X86_64=y
CONFIG_CRYPTO_SHA256_SSSE3=y
CONFIG_CRYPTO_SHA512_SSSE3=y

# ============================================================================
# Cryptographic Options
# ============================================================================
CONFIG_CRYPTO=y
CONFIG_CRYPTO_ALGAPI=y
CONFIG_CRYPTO_HASH=y
CONFIG_CRYPTO_MANAGER=y
CONFIG_CRYPTO_CBC=y
CONFIG_CRYPTO_ECB=y
CONFIG_CRYPTO_XTS=y
CONFIG_CRYPTO_CTR=y
CONFIG_CRYPTO_CCM=y
CONFIG_CRYPTO_GCM=y
CONFIG_CRYPTO_SHA1=y
CONFIG_CRYPTO_SHA256=y
CONFIG_CRYPTO_SHA512=y
CONFIG_CRYPTO_AES=y
CONFIG_CRYPTO_ARC4=y
CONFIG_CRYPTO_DES=y
CONFIG_CRYPTO_3DES=y
CONFIG_CRYPTO_BLOWFISH=y
CONFIG_CRYPTO_TWOFISH=y
CONFIG_CRYPTO_SERPENT=y
CONFIG_CRYPTO_AES=y
CONFIG_CRYPTO_ARC4=y
CONFIG_CRYPTO_DES=y
CONFIG_CRYPTO_3DES=y
CONFIG_CRYPTO_BLOWFISH=y
CONFIG_CRYPTO_TWOFISH=y
CONFIG_CRYPTO_SERPENT=y

# ============================================================================
# Secure Boot Chain
# ============================================================================
CONFIG_EFI_STUB=y
CONFIG_EFI_SECURE_BOOT_LOCK_DOWN=y
CONFIG_EFI_SECURE_BOOT=y
CONFIG_EFI_SECURE_BOOT_SLM=y
CONFIG_EFI_SECURE_BOOT_SLM_POLICY=y

# ============================================================================
# Security Modules
# ============================================================================
CONFIG_SECURITY_APPARMOR=y
CONFIG_SECURITY_APPARMOR_BOOTPARAM_VALUE=1
CONFIG_SECURITY_APPARMOR_HASH=y
CONFIG_SECURITY_APPARMOR_HASH_DEFAULT=y
CONFIG_DEFAULT_SECURITY_APPARMOR=y

# ============================================================================
# Mandatory Access Control
# ============================================================================
CONFIG_SECURITY_APPARMOR=y
CONFIG_SECURITY_APPARMOR_BOOTPARAM_VALUE=1
CONFIG_SECURITY_APPARMOR_HASH=y
CONFIG_SECURITY_APPARMOR_HASH_DEFAULT=y
CONFIG_DEFAULT_SECURITY_APPARMOR=y

# ============================================================================
# Hardened Usercopy
# ============================================================================
CONFIG_HARDENED_USERCOPY=y
CONFIG_HARDENED_USERCOPY_FALLBACK=y
CONFIG_FORTIFY_SOURCE=y
CONFIG_INIT_ON_ALLOC_DEFAULT_ON=y
CONFIG_INIT_ON_FREE_DEFAULT_ON=y

# ============================================================================
# GCC Plugins for Security
# ============================================================================
CONFIG_GCC_PLUGIN_STACKLEAK=y
CONFIG_GCC_PLUGIN_STRUCTLEAK=y
CONFIG_GCC_PLUGIN_STRUCTLEAK_BYREF=y
CONFIG_GCC_PLUGIN_STRUCTLEAK_BYREF_ALL=y
CONFIG_GCC_PLUGIN_STRUCTLEAK_VERBOSE=y
CONFIG_GCC_PLUGIN_RANDSTRUCT=y
CONFIG_GCC_PLUGIN_LATENT_ENTROPY=y
CONFIG_GCC_PLUGIN_RANDSTRUCT=y
CONFIG_GCC_PLUGIN_LATENT_ENTROPY=y
CONFIG_GCC_PLUGIN_STRUCTLEAK=y

# ============================================================================
# Panic and Oops Handling
# ============================================================================
CONFIG_PANIC_ON_OOPS=y
CONFIG_PANIC_TIMEOUT=5
CONFIG_BOOTPARAM_SOFTLOCKUP_PANIC=y
CONFIG_BOOTPARAM_HARDLOCKUP_PANIC=y
CONFIG_BOOTPARAM_HUNG_TASK_PANIC=y
CONFIG_WATCHDOG=y
CONFIG_WDT=y
CONFIG_SOFTLOCKUP_DETECTOR=y
CONFIG_HARDLOCKUP_DETECTOR=y
CONFIG_BOOTPARAM_SOFTLOCKUP_PANIC=y
CONFIG_BOOTPARAM_HARDLOCKUP_PANIC=y
CONFIG_BOOTPARAM_HUNG_TASK_PANIC=y

# ============================================================================
# Kernel Lockdown LSM
# ============================================================================
CONFIG_SECURITY_LOCKDOWN_LSM=y
CONFIG_SECURITY_LOCKDOWN_LSM_EARLY=y
CONFIG_SECURITY_LOCKDOWN_LSM_INTEGRITY=y
CONFIG_SECURITY_LOCKDOWN_LSM_CONFIDENTIALITY=y

# ============================================================================
# Kernel Lockdown Features
# ============================================================================
CONFIG_LOCK_DOWN_KERNEL_FORCE_CONFIDENTIALITY=y
CONFIG_LOCK_DOWN_KERNEL_FORCE_INTEGRITY=y
CONFIG_SECURITY_LOCKDOWN_LSM=y
CONFIG_SECURITY_LOCKDOWN_LSM_EARLY=y

# ============================================================================
# Device Mapper Encryption (LUKS2)
# ============================================================================
CONFIG_DM_CRYPT=y
CONFIG_DM_CRYPT=y
CONFIG_CRYPTO_AES=y
CONFIG_CRYPTO_XTS=y
CONFIG_CRYPTO_SHA256=y
CONFIG_CRYPTO_SHA512=y
CONFIG_CRYPTO_HMAC=y
CONFIG_CRYPTO_GF128MUL=y
CONFIG_CRYPTO_CBC=y
CONFIG_CRYPTO_ECB=y
CONFIG_CRYPTO_CTR=y
CONFIG_CRYPTO_CCM=y
CONFIG_CRYPTO_GCM=y

# ============================================================================
# TPM Support
# ============================================================================
CONFIG_TCG_TPM=y
CONFIG_TCG_TIS=y
CONFIG_TCG_TIS_I2C=y
CONFIG_TCG_TIS_I2C_ATMEL=y
CONFIG_TCG_TIS_I2C_INFINEON=y
CONFIG_TCG_TIS_I2C_NUVOTON=y
CONFIG_TCG_TIS_I2C_SAMSUNG=y
CONFIG_TCG_TIS_I2C_ST33=y
CONFIG_TCG_TIS_SPI=y
CONFIG_TCG_TIS_I2C=y
CONFIG_TCG_TIS_I2C_ATMEL=y
CONFIG_TCG_TIS_I2C_INFINEON=y
CONFIG_TCG_TIS_I2C_NUVOTON=y
CONFIG_TCG_TIS_I2C_SAMSUNG=y
CONFIG_TCG_TIS_I2C_ST33=y
CONFIG_TCG_TIS_SPI=y

# ============================================================================
# UEFI Secure Boot
# ============================================================================
CONFIG_EFI=y
CONFIG_EFI_STUB=y
CONFIG_EFI_SECURE_BOOT_LOCK_DOWN=y
CONFIG_EFI_SECURE_BOOT=y
CONFIG_EFI_SECURE_BOOT_SLM=y
CONFIG_EFI_SECURE_BOOT_SLM_POLICY=y
CONFIG_EFI_EMBEDDED_INITRD_SIZE=0x00000000
CONFIG_EFI_TEST=y
CONFIG_EFI_ALLOW_SECURE_BOOT_DISABLE=y

# ============================================================================
# Kernel Integrity Measurement
# ============================================================================
CONFIG_IMA=y
CONFIG_IMA_MEASURE_PCR_LEN=10
CONFIG_IMA_APPRAISE=y
CONFIG_IMA_APPRAISE_BOOTPARAM=y
CONFIG_IMA_APPRAISE_SIG=y
CONFIG_IMA_APPRAISE_SIGFORCE=y
CONFIG_IMA_TRUSTED_KEYRING=y
CONFIG_IMA_LOAD_KEYRING=y
CONFIG_IMA_READ_POLICY=y
CONFIG_IMA_DEFAULT_HASH="sha256"
CONFIG_IMA_DEFAULT_TEMPLATE="ima-sig"
CONFIG_IMA_APPRAISE_MODULES=y
CONFIG_IMA_APPRAISE_SIGFORCE=y

# ============================================================================
# Extended Verification Module
# ============================================================================
CONFIG_EVM=y
CONFIG_EVM_HMAC_VERSION=2
CONFIG_EVM_ATTR_SECURITY_GPIO=y
CONFIG_EVM_EXTRA_SMACK_LABELS=y
CONFIG_EVM_APPRAISE=y
CONFIG_EVM_APPRAISE_MODULES=y
CONFIG_EVM_APPRAISE_SIG=y
CONFIG_EVM_APPRAISE_SIGFORCE=y

# ============================================================================
# Security Debugging (disabled in production)
# ============================================================================
CONFIG_SECURITY_SELINUX_DEVELOP=y
CONFIG_SECURITY_APPARMOR_DEBUG=y
CONFIG_IMA_APPRAISE_SIGNED_INIT=y
CONFIG_IMA_APPRAISE_DEBUG=y
CONFIG_IMA_TRUSTED_KEYRING=y
CONFIG_IMA_LOAD_KEYRING=y
CONFIG_IMA_READ_POLICY=y
CONFIG_IMA_DEFAULT_HASH="sha256"
CONFIG_IMA_DEFAULT_TEMPLATE="ima-sig"
CONFIG_IMA_APPRAISE_MODULES=y
CONFIG_IMA_APPRAISE_SIGFORCE=y
