# ============================================================================
# Theme Engine
# ============================================================================
setup_theme_engine() {
    log_step "Setting up theme engine..."
    
    sudo mkdir -p "${MOON_THEMES}/dark"
    sudo mkdir -p "${MOON_THEMES}/light"
    sudo mkdir -p "${MOON_THEMES}/gaming"
    
    # Dark Mode Theme (Default)
    sudo cat > "${MOON_THEMES}/dark/moon-dark.css" << 'EOF'
/* Moon OS Dark Theme - Gaming Inspired */
/* Premium, Modern, Beautiful, Minimal */

@theme {
  --moon-bg-primary: #0a0a0f;
  --moon-bg-secondary: #12121a;
  --moon-bg-tertiary: #1a1a25;
  --moon-bg-elevated: #222233;
  --moon-bg-hover: #2a2a3a;
  --moon-bg-active: #333344;
  
  --moon-text-primary: #ffffff;
  --moon-text-secondary: #a0a0b0;
  --moon-text-tertiary: #606070;
  
  --moon-border: #2a2a3a;
  --moon-border-subtle: #1a1a2a;
  
  --moon-accent: #00ff88;
  --moon-accent-hover: #00cc6a;
  --moon-accent-active: #009950;
  
  --moon-error: #ff4444;
  --moon-warning: #ffaa00;
  --moon-success: #00ff88;
  --moon-info: #00aaff;
  
  --moon-shadow: 0 4px 6px -1px rgba(0, 0, 0, 0.3);
  --moon-shadow-glow: 0 0 15px rgba(0, 255, 136, 0.3);
  
  --moon-radius-sm: 6px;
  --moon-radius-md: 10px;
  --moon-radius-lg: 16px;
  --moon-radius-xl: 24px;
}

/* Panel Styling */
.moon-panel {
  background: var(--moon-bg-primary);
  border: 1px solid var(--moon-border-subtle);
  border-radius: var(--moon-radius-lg);
  backdrop-filter: blur(20px);
  box-shadow: var(--moon-shadow);
}

/* Button Styling */
.moon-button {
  background: var(--moon-bg-tertiary);
  border: 1px solid var(--moon-border);
  border-radius: var(--moon-radius-md);
  color: var(--moon-text-primary);
  padding: 8px 16px;
  transition: all 0.2s ease;
}

.moon-button:hover {
  background: var(--moon-bg-hover);
  border-color: var(--moon-accent);
  box-shadow: var(--moon-shadow-glow);
}

.moon-button.primary {
  background: var(--moon-accent);
  color: #000000;
  border: none;
}

.moon-button.primary:hover {
  background: var(--moon-accent-hover);
  box-shadow: var(--moon-shadow-glow);
}

/* Card Styling */
.moon-card {
  background: var(--moon-bg-secondary);
  border: 1px solid var(--moon-border-subtle);
  border-radius: var(--moon-radius-lg);
  padding: 16px;
}

/* Gaming Glow Effect */
.gaming-glow {
  box-shadow: 0 0 10px rgba(0, 255, 136, 0.5),
              0 0 20px rgba(0, 255, 136, 0.3),
              0 0 30px rgba(0, 255, 136, 0.1);
}

/* RGB Animation */
@keyframes rgb-cycle {
  0% { filter: hue-rotate(0deg); }
  100% { filter: hue-rotate(360deg); }
}

.rgb-animation {
  animation: rgb-cycle 5s linear infinite;
}

/* Neon Text */
.neon-text {
  color: var(--moon-accent);
  text-shadow: 0 0 10px var(--moon-accent),
               0 0 20px var(--moon-accent),
               0 0 30px var(--moon-accent);
}

/* Smooth Transitions */
.smooth-transition {
  transition: all 0.3s cubic-bezier(0.4, 0, 0.2, 1);
}

/* Blur Effect */
.glass-effect {
  backdrop-filter: blur(20px) saturate(180%);
  background: rgba(10, 10, 15, 0.7);
}

/* Gaming Dashboard Styling */
.gaming-dashboard {
  background: linear-gradient(135deg, #0a0a0f 0%, #1a1a25 100%);
  border: 1px solid var(--moon-accent);
  border-radius: var(--moon-radius-xl);
  box-shadow: var(--moon-shadow-glow);
}

/* Performance Monitor */
.perf-monitor {
  background: var(--moon-bg-secondary);
  border-radius: var(--moon-radius-md);
  padding: 8px 12px;
  font-family: 'JetBrains Mono', monospace;
}

/* Widget Styling */
.moon-widget {
  background: var(--moon-bg-secondary);
  border: 1px solid var(--moon-border-subtle);
  border-radius: var(--moon-radius-lg);
  backdrop-filter: blur(10px);
}

/* Scrollbar Styling */
::-webkit-scrollbar {
  width: 8px;
  height: 8px;
}

::-webkit-scrollbar-track {
  background: var(--moon-bg-primary);
}

::-webkit-scrollbar-thumb {
  background: var(--moon-bg-tertiary);
  border-radius: 4px;
}

::-webkit-scrollbar-thumb:hover {
  background: var(--moon-bg-hover);
}

/* Selection Styling */
::selection {
  background: var(--moon-accent);
  color: #000000;
}

/* Focus Styling */
*:focus {
  outline: none;
  box-shadow: 0 0 0 2px var(--moon-accent);
}

/* Animation Classes */
@keyframes fadeIn {
  from { opacity: 0; }
  to { opacity: 1; }
}

@keyframes slideUp {
  from { transform: translateY(20px); opacity: 0; }
  to { transform: translateY(0); opacity: 1; }
}

@keyframes slideDown {
  from { transform: translateY(-20px); opacity: 0; }
  to { transform: translateY(0); opacity: 1; }
}

@keyframes scaleIn {
  from { transform: scale(0.9); opacity: 0; }
  to { transform: scale(1); opacity: 1; }
}

@keyframes pulse {
  0%, 100% { opacity: 1; }
  50% { opacity: 0.5; }
}

@keyframes glow {
  0%, 100% { box-shadow: 0 0 5px var(--moon-accent); }
  50% { box-shadow: 0 0 20px var(--moon-accent); }
}

.animate-fadeIn { animation: fadeIn 0.3s ease; }
.animate-slideUp { animation: slideUp 0.3s ease; }
.animate-slideDown { animation: slideDown 0.3s ease; }
.animate-scaleIn { animation: scaleIn 0.3s ease; }
.animate-pulse { animation: pulse 2s infinite; }
.animate-glow { animation: glow 2s infinite; }
EOF
    
    log_design "Dark theme created"
}

