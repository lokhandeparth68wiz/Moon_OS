// Moon OS Gaming Dashboard JavaScript
// Real-time performance monitoring

class MoonDashboard {
    constructor() {
        this.updateInterval = 100; // 100ms updates
        this.fpsHistory = [];
        this.maxFpsHistory = 100;
        this.startTime = Date.now();
        
        this.init();
    }
    
    init() {
        this.updateTime();
        this.updatePerformance();
        this.setupEventListeners();
        
        setInterval(() => this.updateTime(), 1000);
        setInterval(() => this.updatePerformance(), this.updateInterval);
        setInterval(() => this.updateFpsGraph(), 100);
    }
    
    updateTime() {
        const now = new Date();
        const timeStr = now.toLocaleTimeString('en-US', { hour12: false });
        document.getElementById('time').textContent = timeStr;
        
        // Update uptime
        const elapsed = Math.floor((Date.now() - this.startTime) / 1000);
        const hours = Math.floor(elapsed / 3600);
        const minutes = Math.floor((elapsed % 3600) / 60);
        document.getElementById('uptime').textContent = `Uptime: ${hours}h ${minutes}m`;
    }
    
    updatePerformance() {
        // Simulate performance data (in real implementation, this would read from system)
        const cpuUsage = Math.random() * 30 + 40; // 40-70%
        const gpuUsage = Math.random() * 40 + 50; // 50-90%
        const ramUsage = Math.random() * 20 + 60; // 60-80%
        const cpuTemp = Math.floor(Math.random() * 20 + 50); // 50-70°C
        const gpuTemp = Math.floor(Math.random() * 25 + 55); // 55-80°C
        const cpuFreq = (Math.random() * 1.5 + 3.5).toFixed(2); // 3.5-5.0 GHz
        const gpuVram = Math.floor(Math.random() * 4000 + 6000); // 6-10 GB
        const ramUsed = (Math.random() * 4 + 12).toFixed(1); // 12-16 GB
        const ramTotal = 32;
        const netSpeed = (Math.random() * 50 + 10).toFixed(1); // 10-60 MB/s
        const fps = Math.floor(Math.random() * 30 + 120); // 120-150 FPS
        
        // Update CPU
        document.getElementById('cpu-usage').textContent = `${Math.floor(cpuUsage)}%`;
        document.getElementById('cpu-bar').style.width = `${cpuUsage}%`;
        document.getElementById('cpu-temp').textContent = `${cpuTemp}°C`;
        document.getElementById('cpu-freq').textContent = `${cpuFreq} GHz`;
        
        // Update GPU
        document.getElementById('gpu-usage').textContent = `${Math.floor(gpuUsage)}%`;
        document.getElementById('gpu-bar').style.width = `${gpuUsage}%`;
        document.getElementById('gpu-temp').textContent = `${gpuTemp}°C`;
        document.getElementById('gpu-vram').textContent = `${gpuVram} MB`;
        
        // Update RAM
        document.getElementById('ram-usage').textContent = `${Math.floor(ramUsage)}%`;
        document.getElementById('ram-bar').style.width = `${ramUsage}%`;
        document.getElementById('ram-used').textContent = `${ramUsed} GB`;
        document.getElementById('ram-total').textContent = `${ramTotal} GB`;
        
        // Update Network
        document.getElementById('net-speed').textContent = `${netSpeed} MB/s`;
        document.getElementById('net-bar').style.width = `${Math.min(netSpeed * 2, 100)}%`;
        document.getElementById('net-up').textContent = `↑ ${(netSpeed * 0.3).toFixed(1)} MB/s`;
        document.getElementById('net-down').textContent = `↓ ${(netSpeed * 0.7).toFixed(1)} MB/s`;
        
        // Update FPS
        document.getElementById('fps').textContent = fps;
        this.fpsHistory.push(fps);
        if (this.fpsHistory.length > this.maxFpsHistory) {
            this.fpsHistory.shift();
        }
        
        // Color code FPS
        const fpsElement = document.getElementById('fps');
        if (fps >= 144) {
            fpsElement.style.color = '#00ff88';
        } else if (fps >= 100) {
            fpsElement.style.color = '#ffaa00';
        } else {
            fpsElement.style.color = '#ff4444';
        }
    }
    
    updateFpsGraph() {
        const canvas = document.getElementById('fps-graph');
        const ctx = canvas.getContext('2d');
        
        canvas.width = canvas.offsetWidth;
        canvas.height = canvas.offsetHeight;
        
        ctx.clearRect(0, 0, canvas.width, canvas.height);
        
        if (this.fpsHistory.length < 2) return;
        
        const step = canvas.width / this.maxFpsHistory;
        const scale = canvas.height / 200; // Max 200 FPS
        
        // Draw graph
        ctx.beginPath();
        ctx.strokeStyle = '#00ff88';
        ctx.lineWidth = 2;
        
        this.fpsHistory.forEach((fps, i) => {
            const x = i * step;
            const y = canvas.height - (fps * scale);
            
            if (i === 0) {
                ctx.moveTo(x, y);
            } else {
                ctx.lineTo(x, y);
            }
        });
        
        ctx.stroke();
        
        // Draw glow effect
        ctx.shadowBlur = 10;
        ctx.shadowColor = '#00ff88';
        ctx.stroke();
        ctx.shadowBlur = 0;
    }
    
    setupEventListeners() {
        // Game play buttons
        document.querySelectorAll('.game-play').forEach(btn => {
            btn.addEventListener('click', (e) => {
                const game = e.target.closest('.game-card').dataset.game;
                this.launchGame(game);
            });
        });
        
        // Toggle switches
        document.querySelectorAll('.toggle input').forEach(toggle => {
            toggle.addEventListener('change', (e) => {
                const setting = e.target.id;
                const enabled = e.target.checked;
                this.toggleSetting(setting, enabled);
            });
        });
    }
    
    launchGame(game) {
        console.log(`Launching ${game}...`);
        // In real implementation, this would launch the game via Steam/Proton
    }
    
    toggleSetting(setting, enabled) {
        console.log(`Setting ${setting}: ${enabled}`);
        // In real implementation, this would toggle the setting
    }
}

// Initialize dashboard
document.addEventListener('DOMContentLoaded', () => {
    new MoonDashboard();
});
JSEOF
    
    log_design "Gaming dashboard created"
}

