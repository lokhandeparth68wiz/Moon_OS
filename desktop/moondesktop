    log_info "All desktop components configured!"
    log_info "Gaming Dashboard: /usr/share/moonapps/gaming-dashboard/"
    log_info "Control Center: /usr/share/moonapps/control-center/"
    log_info "Software Center: /usr/share/moonapps/software-center/"
    log_info "Theme Engine: /usr/share/moonapps/theme-engine/"
    log_info "RGB Controller: /usr/share/moonapps/rgb-controller/"
    log_info "Widgets: /usr/share/moonos/widgets/"
}

# ============================================================================
# Main
# ============================================================================
main() {
    case "${1:-setup}" in
        setup)
            setup_all_desktop
            ;;
        help|*)
            echo "Moon OS Desktop Environment v${MOON_DESKTOP_VERSION}"
            echo ""
            echo "Usage: $0 <command>"
            echo ""
            echo "Commands:"
            echo "  setup    Setup desktop environment"
            echo "  help     Show this help"
            ;;
    esac
}

main "$@"
