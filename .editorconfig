root = true

[*]
charset = utf-8
end_of_line = lf
insert_final_newline = true
trim_trailing_whitespace = true
indent_style = space
indent_size = 4

[*.{sh,bash}]
indent_style = tab
indent_size = 4

[*.{py}]
indent_style = space
indent_size = 4

[*.{c,h}]
indent_style = tab
indent_size = 8

[*.{cpp,hpp}]
indent_style = tab
indent_size = 8

[Makefile]
indent_style = tab
indent_size = 8

[*.md]
trim_trailing_whitespace = false

[*.{yml,yaml}]
indent_style = space
indent_size = 2

[*.json]
indent_style = space
indent_size = 2

[*.toml]
indent_style = space
indent_size = 2
