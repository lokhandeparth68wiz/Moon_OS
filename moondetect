# Apply filesystem optimizations
apply_filesystem_optimizations() {
    log_step "Applying filesystem optimizations..."
    
    # Detect root filesystem
    local root_fs=$(mount | grep " / " | awk '{print $5}')
    
    case "$root_fs" in
        ext4)
            log_info "Optimizing ext4..."
            # Already optimized with proper mount options
            ;;
        btrfs)
            log_info "Optimizing btrfs..."
            sudo pacman -S --needed --noconfirm btrfs-progs 2>/dev/null || true
            ;;
        *)
            log_info "Filesystem: $root_fs (no specific optimizations)"
            ;;
    esac
    
    log_info "Filesystem optimizations applied"
}

# Apply audio optimizations
apply_audio_optimizations() {
    log_step "Applying audio optimizations..."
    
    # Install audio packages
    sudo pacman -S --needed --noconfirm \
        pipewire \
        pipewire-pulse \
        pipewire-alsa \
        pipewire-jack \
        lib32-pipewire \
        wireplumber \
        2>/dev/null || true
    
    # Enable PipeWire services
    sudo systemctl enable pipewire
    sudo systemctl enable pipewire-pulse
    sudo systemctl enable wireplumber
    
    # Create audio optimization configuration
    sudo mkdir -p /etc/security/limits.d
    cat > /tmp/99-audio.conf << 'EOF'
# Moon OS Audio Optimizations
@audio - rtprio 95
@audio - memlock unlimited
@audio - nice -10
EOF
    sudo mv /tmp/99-audio.conf /etc/security/limits.d/
    
    log_info "Audio optimizations applied"
}

# Apply network optimizations
apply_network_optimizations() {
    log_step "Applying network optimizations..."
    
    # Install network packages
    sudo pacman -S --needed --noconfirm \
        networkmanager \
        iwd \
        wpa_supplicant \
        2>/dev/null || true
    
    # Enable services
    sudo systemctl enable NetworkManager
    sudo systemctl enable iwd
    
    # Create network optimization configuration
    sudo cat > /etc/NetworkManager/conf.d/99-gaming.conf << 'EOF'
[main]
dns=systemd-resolved

[connection]
wifi.powersave=2

[device]
wifi.scan-rand-mac-address=yes
EOF
    
    log_info "Network optimizations applied"
}

# Apply display optimizations
apply_display_optimizations() {
    log_step "Applying display optimizations..."
    
    # Install display packages
    sudo pacman -S --needed --noconfirm \
        xorg-server \
        xorg-drivers \
        xorg-xrandr \
        xorg-xset \
        wayland \
        wayland-protocols \
        2>/dev/null || true
    
    # Create display configuration
    sudo mkdir -p /etc/X11/xorg.conf.d
    cat > /tmp/10-display.conf << 'EOF'
Section "Screen"
    Identifier "Default Screen"
    Option "AllowIndirectGLXProtocol" "off"
    Option "TripleBuffer" "True"
EndSection
EOF
    sudo mv /tmp/10-display.conf /etc/X11/xorg.conf.d/
    
    # Create Wayland configuration
    sudo mkdir -p /etc/environment.d
    cat > /tmp/10-display.conf << 'EOF'
MOZ_ENABLE_WAYLAND=1
GDK_BACKEND=wayland,x11
QT_QPA_PLATFORM=wayland;xcb
SDL_VIDEODRIVER=wayland
CLUTTER_BACKEND=wayland
XDG_SESSION_TYPE=wayland
EOF
    sudo mv /tmp/10-display.conf /etc/environment.d/10-display.conf
    
    log_info "Display optimizations applied"
}

# Apply security optimizations
apply_security_optimizations() {
    log_step "Applying security optimizations..."
    
    # Configure firewall
    sudo pacman -S --needed --noconfirm \
        firewalld \
        2>/dev/null || true
    
    sudo systemctl enable firewalld
    
    # Create gaming-friendly firewall rules
    sudo cat > /tmp/gaming.xml << 'EOF'
<?xml version="1.0" encoding="utf-8"?>
<zone>
  <short>Gaming</short>
  <description>Firewall zone for gaming applications</description>
  <service name="dhcpv6-client"/>
  <service name="ssh"/>
  <port protocol="tcp" port="27015-27030"/>
  <port protocol="udp" port="27000-27100"/>
  <port protocol="tcp" port="3478-4380"/>
  <port protocol="udp" port="3478-4380"/>
  <port protocol="tcp" port="27036-27037"/>
  <port protocol="udp" port="4380"/>
  <port protocol="tcp" port="27015-27050"/>
  <port protocol="udp" port="3480"/>
  <port protocol="tcp" port="1935"/>
  <port protocol="tcp" port="3478"/>
  <port protocol="udp" port="3478"/>
  <port protocol="tcp" port="3479"/>
  <port protocol="udp" port="3479"/>
  <port protocol="tcp" port="3480"/>
</zone>
EOF
    sudo firewall-cmd --permanent --new-zone=gaming 2>/dev/null || true
    sudo firewall-cmd --permanent --zone=gaming --add-source="" 2>/dev/null || true
    sudo firewall-cmd --reload 2>/dev/null || true
    
    log_info "Security optimizations applied"
}

# Generate hardware report
generate_report() {
    log_step "Generating hardware report..."
    
    local report="/tmp/moon-hardware-report.txt"
    
    cat > "$report" << EOF
Moon OS Hardware Detection Report
===================================
Generated: $(date)

CPU Information:
$(lscpu | grep -E "^(Architecture|CPU\(s\)|Vendor|Model|Thread|Core|Socket|MHz|Cache)")

GPU Information:
$(lspci | grep -E "VGA|3D|Display")

Memory Information:
$(free -h)

Storage Information:
$(lsblk -d -o NAME,SIZE,TYPE,ROTA)

Network Information:
$(ip link show | grep -E "^[0-9]+")

Audio Information:
$(aplay -l 2>/dev/null || echo "No audio devices")

USB Information:
$(lsusb 2>/dev/null || echo "No USB devices")

Input Information:
$(cat /proc/bus/input/devices | grep -E "^[IN]:|Name=")

Display Information:
$(xrandr 2>/dev/null | head -20 || echo "No display detected")

Gaming Controllers:
$(ls /dev/input/js* 2>/dev/null || echo "No controllers detected")
EOF
    
    log_info "Hardware report saved to: $report"
}

