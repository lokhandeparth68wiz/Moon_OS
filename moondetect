    echo "=========================================="
    echo ""
    
    detect_cpu
    detect_gpu
    detect_audio
    detect_network
    detect_storage
    detect_input
    detect_laptop
    detect_controllers
    
    echo ""
    echo "=========================================="
    echo "  Applying Optimizations"
