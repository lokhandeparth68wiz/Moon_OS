#!/bin/bash
# Moon OS Vulkan Optimizer
# Automatically optimizes Vulkan for gaming

# Detect GPU vendor
GPU_VENDOR=""
if lspci | grep -qi nvidia; then
    GPU_VENDOR="nvidia"
elif lspci | grep -qi "amd\|radeon"; then
    GPU_VENDOR="amd"
elif lspci | grep -qi intel; then
