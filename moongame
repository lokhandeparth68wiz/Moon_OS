EOF
    
    # Create shader cache manager
    sudo cat > /usr/local/bin/moon-shader-cache << 'SCRIPT'
#!/bin/bash
# Moon OS Shader Cache Manager

set -euo pipefail

ACTION="${1:-status}"
CACHE_DIR="${HOME}/.cache/moonos/shader"

case "$ACTION" in
    status)
        echo "Shader Cache Status:"
        echo "  Location: $CACHE_DIR"
        echo "  Size: $(du -sh "$CACHE_DIR" 2>/dev/null | cut -f1 || echo "0")"
        echo "  Files: $(find "$CACHE_DIR" -type f 2>/dev/null | wc -l || echo "0")"
        ;;
    clear)
        echo "Clearing shader cache..."
        rm -rf "$CACHE_DIR"/*
        echo "Shader cache cleared"
        ;;
    optimize)
        echo "Optimizing shader cache..."
        # Remove old/unused shaders
        find "$CACHE_DIR" -type f -mtime +30 -delete 2>/dev/null || true
        echo "Shader cache optimized"
        ;;
    pre-cache)
        echo "Pre-caching shaders..."
        # Pre-cache common shaders
        # This would involve running games briefly to generate cache
        echo "Shader pre-caching complete"
        ;;
    *)
        echo "Usage: $0 {status|clear|optimize|pre-cache}"
        ;;
esac
SCRIPT
    sudo chmod +x /usr/local/bin/moon-shader-cache
    
    log_info "Shader cache optimization configured"
}

