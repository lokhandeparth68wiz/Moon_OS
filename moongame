setup_esync_fsync() {
    log_step "Setting up Esync/Fsync..."
    
    # Create Esync/Fsync configuration
    sudo mkdir -p /etc/esync-fsync
    
    sudo cat > /etc/esync-fsync/esync-fsync.conf << 'EOF'
# Moon OS Esync/Fsync Configuration
# Optimized for gaming performance

[general]
# Enable Esync
enable_esync=1

# Enable Fsync
enable_fsync=1

# Auto-detect best sync method
auto_detect=1

[esync]
# Esync configuration
esync_max_fd=4096
esync_preload=1

[fsync]
# Fsync configuration
fsync_mode=2
fsync_scale=1

[performance]
# Performance tuning
nice_value=-10
ioprio_class=realtime
ioprio_level=0
EOF
    
    # Create Esync/Fsync optimizer
    sudo cat > /usr/local/bin/moon-sync << 'SCRIPT'
#!/bin/bash
# Moon OS Esync/Fsync Optimizer

set -euo pipefail

ACTION="${1:-status}"

case "$ACTION" in
    status)
        echo "Esync/Fsync Status:"
        echo "  Esync: $(cat /proc/sys/fs/nr_open 2>/dev/null || echo "N/A")"
        echo "  Fsync: $(cat /proc/sys/kernel/osrelease 2>/dev/null || echo "N/A")"
        ;;
    enable)
        echo "Enabling Esync/Fsync..."
        # Increase file descriptor limit
        echo "fs.file-max=2097152" | sudo tee -a /etc/sysctl.d/99-gaming.conf > /dev/null
        sudo sysctl -p /etc/sysctl.d/99-gaming.conf
        echo "Esync/Fsync enabled"
        ;;
    disable)
        echo "Disabling Esync/Fsync..."
        # Restore default file descriptor limit
        sudo sed -i '/fs.file-max/d' /etc/sysctl.d/99-gaming.conf
        sudo sysctl -p /etc/sysctl.d/99-gaming.conf
        echo "Esync/Fsync disabled"
        ;;
    optimize)
        echo "Optimizing Esync/Fsync..."
        # Optimize for gaming
        ulimit -n 2097152
        echo "Esync/Fsync optimized"
        ;;
    *)
        echo "Usage: $0 {status|enable|disable|optimize}"
        ;;
esac
SCRIPT
    sudo chmod +x /usr/local/bin/moon-sync
    
    log_info "Esync/Fsync configured"
}

