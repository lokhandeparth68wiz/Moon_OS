        echo "  Preempt RT: Enabled"
        ;;
    apply)
        echo "Applying kernel patches..."
        echo "  This may take a while..."
        
        # Download kernel source
        cd /tmp
        wget -q "https://cdn.kernel.org/pub/linux/kernel/v6.x/linux-${KERNEL_VERSION}.tar.xz"
        tar xf "linux-${KERNEL_VERSION}.tar.xz"
        cd "linux-${KERNEL_VERSION}"
        
        # Apply patches
        patch -p1 < /etc/kernel-patches/gaming-optimizations.patch
        patch -p1 < /etc/kernel-patches/gaming-config.patch
        
        echo "Kernel patches applied"
        echo "  Run 'make menuconfig' to configure"
        echo "  Run 'make -j\$(nproc)' to build"
        ;;
    remove)
        echo "Removing kernel patches..."
        cd /tmp/linux-${KERNEL_VERSION} 2>/dev/null && git checkout . 2>/dev/null || true
        echo "Kernel patches removed"
        ;;
    list)
        echo "Available kernel patches:"
        ls -1 /etc/kernel-patches/*.patch
        ;;
    *)
        echo "Usage: $0 {status|apply|remove|list} [kernel-version]"
        ;;
esac
SCRIPT
    sudo chmod +x /usr/local/bin/moon-kernel-patch
    
    log_info "Custom kernel patches configured"
}

