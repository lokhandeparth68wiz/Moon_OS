#!/bin/bash
# MOONGAME - Moon OS Gaming Automation System
# Automatic GameMode, MangoHud, Proton, Vulkan, and all gaming optimizations

set -euo pipefail

MOON_GAME_VERSION="1.0.0"
MOON_GAME_CONFIG="/etc/moongame"
MOON_GAME_PROFILES="${MOON_GAME_CONFIG}/profiles"
MOON_GAME_CACHE="${MOON_GAME_CONFIG}/cache"

# Color codes
RED='\033[0;31m'
GREEN='\033[0;32m'
YELLOW='\033[1;33m'
BLUE='\033[0;34m'
MAGENTA='\033[0;35m'
CYAN='\033[0;36m'
NC='\033[0m'

log_info() { echo -e "${GREEN}[INFO]${NC} $1"; }
log_warn() { echo -e "${YELLOW}[WARN]${NC} $1"; }
log_error() { echo -e "${RED}[ERROR]${NC} $1"; }
log_step() { echo -e "${BLUE}[STEP]${NC} $1"; }
log_gaming() { echo -e "${MAGENTA}[GAME]${NC} $1"; }

# ============================================================================
# Initialize Gaming System
# ============================================================================
init_gaming_system() {
    log_step "Initializing gaming system..."
    
    sudo mkdir -p "${MOON_GAME_CONFIG}"
    sudo mkdir -p "${MOON_GAME_PROFILES}"
    sudo mkdir -p "${MOON_GAME_CACHE}"
    sudo mkdir -p "${MOON_GAME_CACHE}/shader"
    sudo mkdir -p "${MOON_GAME_CACHE}/pipeline"
    sudo mkdir -p "${MOON_GAME_CACHE}/vulkan"
    
    # Install gaming dependencies
    sudo pacman -S --needed --noconfirm \
        gamemode lib32-gamemode \
        mangohud lib32-mangohud \
        gamescope \
        wine wine-mono wine-gecko lib32-wine \
        proton-gecko \
        dxvk lib32-dxvk \
        vkd3d lib32-vkd3d \
        vulkan-icd-loader lib32-vulkan-icd-loader \
        vulkan-validation-layers lib32-vulkan-validation-layers \
        mesa lib32-mesa \
        lib32-nvidia-utils nvidia-utils \
        lib32-vulkan-radeon vulkan-radeon \
        lib32-vulkan-intel vulkan-intel \
        2>/dev/null || true
    
    log_info "Gaming system initialized"
}

# ============================================================================
# Automatic GameMode
# ============================================================================
setup_automatic_gamemode() {
    log_step "Setting up automatic GameMode..."
    
    # Create GameMode configuration
    sudo mkdir -p /etc/gamemode
    
    sudo cat > /etc/gamemode/gamemode.ini << 'EOF'
# Moon OS GameMode Configuration
# Optimized for maximum gaming performance

[general]
enabled=1
gpu_device=0
affinity=0-15
soft_idle=5000
ioprio=0

[cpu]
park_cores=0
pin_cores=1

[gpu]
apply_gpu_optimisations=1
gpu_core_clock=0
gpu_mem_clock=0
gpu_power_state=0

[ioprio]
io_class=2

[scheduler]
sched_policy=0
sched_priority=4

[nice]
nice_value=0

[platform]
platform_type=0
EOF
    
    # Create GameMode wrapper for automatic activation
    sudo cat > /usr/local/bin/moon-gamemode << 'SCRIPT'
#!/bin/bash
# Moon OS GameMode Wrapper
# Automatically activates GameMode for games

GAME_MODE=0

# Check if GameMode is available
if ! command -v gamemoded &>/dev/null; then
    echo "GameMode not installed"
    exec "$@"
fi

# Detect if running a game
detect_game() {
    local exec_name=$(basename "$1")
    
    # List of known game executables
    local game_patterns=(
        "steam"
        "proton"
        "wine"
        "lutris"
        "heroic"
        "game"
        "unity"
        "unreal"
        "godot"
        "cryengine"
    )
    
    for pattern in "${game_patterns[@]}"; do
        if [[ "$exec_name" == *"$pattern"* ]]; then
            return 0
        fi
    done
    
    return 1
}

# Activate GameMode
activate_gamemode() {
    if [[ $GAME_MODE -eq 0 ]]; then
        gamemoded -r 2>/dev/null || true
        GAME_MODE=1
        echo "GameMode activated"
    fi
}

# Deactivate GameMode
deactivate_gamemode() {
    if [[ $GAME_MODE -eq 1 ]]; then
        gamemoded -k 2>/dev/null || true
        GAME_MODE=0
        echo "GameMode deactivated"
    fi
}

# Trap exit
trap deactivate_gamemode EXIT

# Check if command is a game
if detect_game "$1"; then
    activate_gamemode
fi

# Execute the original command
exec "$@"
SCRIPT
    sudo chmod +x /usr/local/bin/moon-gamemode
    
    # Create systemd service for automatic GameMode
    sudo cat > /etc/systemd/system/moon-gamemode.service << 'EOF'
[Unit]
Description=Moon OS GameMode Service
After=network.target

[Service]
Type=simple
ExecStart=/usr/bin/gamemoded
Restart=on-failure
User=root

[Install]
WantedBy=multi-user.target
EOF
    
    sudo systemctl enable moon-gamemode
    
    log_info "Automatic GameMode configured"
}

