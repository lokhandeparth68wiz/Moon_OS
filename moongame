#!/bin/bash
# Moon OS Wine Optimizer

set -euo pipefail

ACTION="${1:-status}"
PREFIX="${2:-~/.wine}"

case "$ACTION" in
    status)
        echo "Wine Status:"
        echo "  Version: $(wine --version 2>/dev/null || echo "Not installed")"
        echo "  Prefix: $PREFIX"
        echo "  Esync: $(cat /proc/sys/fs/nr_open 2>/dev/null || echo "N/A")"
        ;;
    optimize)
        echo "Optimizing Wine..."
        
        # Set Wine environment variables
        export WINEDEBUG=-all
        export WINEESYNC=1
        export WINEFSYNC=1
        export DXVK_ASYNC=1
        export DXVK_HUD="fps,frametimes"
        export VKD3D_CONFIG=dxr
        export MANGOHUD=1
        
        # Optimize Wine prefix
        if [[ -d "$PREFIX" ]]; then
            # Set Windows version to Windows 10
            wine reg add "HKEY_CURRENT_USER\Software\Wine" /v Version /t REG_SZ /d "win10" /f 2>/dev/null || true
            
            # Enable VSync
            wine reg add "HKEY_CURRENT_USER\Software\Wine\DllOverrides" /v d3d11 /t REG_SZ /d "dxvk" /f 2>/dev/null || true
        fi
        
        echo "Wine optimized"
        ;;
    create)
        echo "Creating optimized Wine prefix..."
        WINEPREFIX="$PREFIX" wineboot --init 2>/dev/null || true
        echo "Wine prefix created"
        ;;
    *)
        echo "Usage: $0 {status|optimize|create} [prefix]"
        ;;
esac
SCRIPT
    sudo chmod +x /usr/local/bin/moon-wine
    
    log_info "Wine tuning configured"
}

