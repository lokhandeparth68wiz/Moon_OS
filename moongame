#!/bin/bash
# Moon OS Proton Wrapper
# Automatically configures Proton for games

# Load Proton configuration
source /etc/proton/proton.conf 2>/dev/null || true

# Set environment variables for Proton
export PROTON_USE_WINED3D=0
export PROTON_NO_ESYNC=0
export PROTON_NO_FSYNC=0

# Enable Esync
if [[ "${enable_esync:-1}" -eq 1 ]]; then
    export PROTON_USE_ESYNC=1
fi

# Enable Fsync
if [[ "${enable_fsync:-1}" -eq 1 ]]; then
    export PROTON_USE_FSYNC=1
fi

# Enable DXVK
if [[ "${enable_dxvk:-1}" -eq 1 ]]; then
    export DXVK_ASYNC=1
    export DXVK_HUD="fps,frametimes,drawcalls,pipelines"
fi

# Enable VKD3D
if [[ "${enable_vkd3d:-1}" -eq 1 ]]; then
    export VKD3D_CONFIG=dxr
fi

# Enable NVIDIA specific settings
if lspci | grep -qi nvidia; then
    export PROTON_ENABLE_NVAPI=1
    export PROTON_ENABLE_NGX_UPDATER=1
    export DXVK_ENABLE_NVAPI=1
    export __GLX_VENDOR_LIBRARY_NAME=nvidia
    export VK_ICD_FILENAMES=/usr/share/vulkan/icd.d/nvidia_icd.json
fi

# Enable AMD specific settings
if lspci | grep -qi "amd\|radeon"; then
    export RADV_PERFTEST=gpl
    export AMD_VULKAN_ICD=RADV
    export VK_ICD_FILENAMES=/usr/share/vulkan/icd.d/radeon_icd.json
fi

# Enable Intel specific settings
if lspci | grep -qi intel; then
    export VK_ICD_FILENAMES=/usr/share/vulkan/icd.d/intel_icd.json
fi

# Enable FSR
if [[ "${enable_fsr:-1}" -eq 1 ]]; then
    export FSR_ENABLE=1
fi

# Enable HDR
if [[ "${enable_hdr:-1}" -eq 1 ]]; then
    export gamescope_hdr_enabled=1
fi

# Enable VRR
if [[ "${enable_vrr:-1}" -eq 1 ]]; then
    export gamescope_vrr_enabled=1
fi

# Execute the original command
exec "$@"
SCRIPT
    sudo chmod +x /usr/local/bin/moon-proton
    
    log_info "Automatic Proton configured"
}

