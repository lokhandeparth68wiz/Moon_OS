        export __GL_SYNC_DISPLAY=0
        ;;
    amd)
        export VK_ICD_FILENAMES=/usr/share/vulkan/icd.d/radeon_icd.json
        export RADV_PERFTEST=gpl
        export RADV_ACO=1
        export RADV_PERF_THREAD=1
        export RADV_DGC=1
        ;;
    intel)
        export VK_ICD_FILENAMES=/usr/share/vulkan/icd.d/intel_icd.json
        export ANV_THREAD=1
        ;;
esac

# General Vulkan optimizations
export VK_INSTANCE_LAYERS=
export VK_LAYER_LUNARG_api_dump=0
export VK_LAYER_LUNARG_core_validation=0
export VK_LAYER_LUNARG_object_tracker=0
export VK_LAYER_LUNARG_parameter_validation=0
export VK_LAYER_LUNARG_swapchain=0
export VK_LAYER_GOOGLE_threading=0
export VK_LAYER_GOOGLE_unique_objects=0

# Enable async compute
export VK_ALLOW_DOWNLOADING_VK_ICD=1

echo "Vulkan optimized for: $GPU_VENDOR"
SCRIPT
    sudo chmod +x /usr/local/bin/moon-vulkan
    
    # Create Vulkan layer configuration
    sudo mkdir -p /etc/vulkan/implicit_layer.d
    
    sudo cat > /etc/vulkan/implicit_layer.d/moon-vulkan.conf << 'EOF'
