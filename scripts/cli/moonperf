#!/bin/bash
# MOONPERF - Moon OS Performance Optimization System
# Automatically configures system for maximum gaming performance

set -euo pipefail

MOON_PERF_VERSION="1.0.0"

# Color codes
RED='\033[0;31m'
GREEN='\033[0;32m'
YELLOW='\033[1;33m'
BLUE='\033[0;34m'
CYAN='\033[0;36m'
NC='\033[0m'

log_info() { echo -e "${GREEN}[INFO]${NC} $1"; }
log_warn() { echo -e "${YELLOW}[WARN]${NC} $1"; }
log_error() { echo -e "${RED}[ERROR]${NC} $1"; }
log_step() { echo -e "${BLUE}[STEP]${NC} $1"; }
log_opt() { echo -e "${CYAN}[OPT]${NC} $1"; }

# ============================================================================
# CPU Optimizations
# ============================================================================
optimize_cpu() {
    log_step "Optimizing CPU..."
    
    # Set CPU governor to performance
    for cpu in /sys/devices/system/cpu/cpu*/cpufreq/scaling_governor; do
        if [[ -f "$cpu" ]]; then
            echo "performance" | sudo tee "$cpu" > /dev/null
            log_opt "CPU $(basename $(dirname $(dirname $cpu))): performance governor"
        fi
    done
    
    # Enable Turbo Boost
    if [[ -f /sys/devices/system/cpu/intel_pstate/no_turbo ]]; then
        echo 0 | sudo tee /sys/devices/system/cpu/intel_pstate/no_turbo > /dev/null
        log_opt "Intel Turbo Boost enabled"
    fi
    
    # Enable AMD P-State
    if [[ -d /sys/devices/system/cpu/amd_pstate ]]; then
        echo "active" | sudo tee /sys/devices/system/cpu/amd_pstate/status > /dev/null
        log_opt "AMD P-State enabled"
    fi
    
    # Optimize CPU frequency
    for cpu in /sys/devices/system/cpu/cpu*/cpufreq/scaling_min_freq; do
        if [[ -f "$cpu" ]]; then
            local max_freq=$(cat ${cpu%/*}/scaling_max_freq)
            echo "$max_freq" | sudo tee "$cpu" > /dev/null
        fi
    done
    
    # Disable CPU idle states
    for cpu in /sys/devices/system/cpu/cpu*/cpuidle/state*/disable; do
        if [[ -f "$cpu" ]]; then
            echo 1 | sudo tee "$cpu" > /dev/null
        fi
    done
    
    log_info "CPU optimization complete"
}

# ============================================================================
# Memory Optimizations
# ============================================================================
optimize_memory() {
    log_step "Optimizing memory..."
    
    # Configure swappiness
    echo 10 | sudo tee /proc/sys/vm/swappiness > /dev/null
    log_opt "Swappiness: 10"
    
    # Configure dirty ratios
    echo 10 | sudo tee /proc/sys/vm/dirty_ratio > /dev/null
    echo 5 | sudo tee /proc/sys/vm/dirty_background_ratio > /dev/null
    log_opt "Dirty ratio: 10%, Background: 5%"
    
    # Configure page cache
    echo 50 | sudo tee /proc/sys/vm/vfs_cache_pressure > /dev/null
    log_opt "VFS cache pressure: 50"
    
    # Configure minimum free memory
    echo 65536 | sudo tee /proc/sys/vm/min_free_kbytes > / zone_reclaim_mode
    echo 0 | sudo tee /proc/sys/vm/zone_reclaim_mode > /dev/null
    log_opt "Zone reclaim mode: disabled"
    
    # Enable KSM (Kernel Same-page Merging)
    echo 1 | sudo tee /proc/sys/kernel/ksm/run > /dev/null
    log_opt "KSM enabled"
    
    # Configure transparent hugepages
    echo madvise | sudo tee /sys/kernel/mm/transparent_hugepage/enabled > /dev/null
    echo madvise | sudo tee /sys/kernel/mm/transparent_hugepage/defrag > /dev/null
    log_opt "Transparent hugepages: madvise"
    
    # Configure ZRAM
    if [[ -b /dev/zram0 ]]; then
        echo lz4 | sudo tee /sys/block/zram0/comp_algorithm > /dev/null
        echo 8G | sudo tee /sys/block/zram0/disksize > /dev/null
        sudo mkswap /dev/zram0
        sudo swapon -p 100 /dev/zram0
        log_opt "ZRAM enabled with lz4 compression"
    fi
    
    # Configure hugetlb
    echo always | sudo tee /sys/kernel/mm/transparent_hugepage/hugetlb/enabled > /dev/null 2>/dev/null || true
    
    log_info "Memory optimization complete"
}

# ============================================================================
# I/O Optimizations
# ============================================================================
optimize_io() {
    log_step "Optimizing I/O..."
    
    # Detect storage type
    for disk in /sys/block/sd* /sys/block/nvme*; do
        if [[ -d "$disk" ]]; then
            local disk_name=$(basename "$disk")
            local rotational=$(cat "$disk/queue/rotational" 2>/dev/null || echo "1")
            local scheduler="mq-deadline"
            
            if [[ "$rotational" == "0" ]]; then
                # SSD/NVMe - use none or mq-deadline
                if [[ "$disk_name" == nvme* ]]; then
                    scheduler="none"
                else
                    scheduler="none"
                fi
                log_opt "$disk_name (SSD/NVMe): scheduler=$scheduler"
            else
                # HDD - use mq-deadline
                scheduler="mq-deadline"
                log_opt "$disk_name (HDD): scheduler=$scheduler"
            fi
            
            echo "$scheduler" | sudo tee "$disk/queue/scheduler" > /dev/null
            
            # Optimize queue settings
            echo 256 | sudo tee "$disk/queue/read_ahead_kb" > /dev/null
            echo 0 | sudo tee "$disk/queue/rq_affinity" > /dev/null
            echo 2 | sudo tee "$disk/queue/nomerges" > /dev/null
            echo 128 | sudo tee "$disk/queue/nr_requests" > /dev/null
        fi
    done
    
    # Configure IO scheduler for all block devices
    for device in /sys/block/*/queue/scheduler; do
        if [[ -f "$device" ]]; then
            local current=$(cat "$device" | grep -o '\[.*\]' | tr -d '[]')
            if [[ "$current" != "none" ]]; then
                echo "none" | sudo tee "$device" > /dev/null 2>/dev/null || true
            fi
        fi
    done
    
    log_info "I/O optimization complete"
}

# ============================================================================
# Network Optimizations
# ============================================================================
optimize_network() {
    log_step "Optimizing network..."
    
    # TCP optimizations
    echo 16777216 | sudo tee /proc/sys/net/core/rmem_max > /dev/null
    echo 16777216 | sudo tee /proc/sys/net/core/wmem_max > /dev/null
    echo "4096 87380 16777216" | sudo tee /proc/sys/net/ipv4/tcp_rmem > /dev/null
    echo "4096 65536 16777216" | sudo tee /proc/sys/net/ipv4/tcp_wmem > /dev/null
    echo 5000 | sudo tee /proc/sys/net/core/netdev_max_backlog > /dev/null
    echo 1 | sudo tee /proc/sys/net/ipv4/tcp_window_scaling > /dev/null
    echo 1 | sudo tee /proc/sys/net/ipv4/tcp_timestamps > /dev/null
    echo 1 | sudo tee /proc/sys/net/ipv4/tcp_sack > /dev/null
    echo 0 | sudo tee /proc/sys/net/ipv4/tcp_no_metrics_save > /dev/null
    echo 1 | sudo tee /proc/sys/net/ipv4/tcp_syncookies > /dev/null
    echo 4096 | sudo tee /proc/sys/net/ipv4/tcp_max_syn_backlog > /dev/null
    echo bbr | sudo tee /proc/sys/net/ipv4/tcp_congestion_control > /dev/null
    
    # Enable BBR
    sudo modprobe tcp_bbr 2>/dev/null || true
    
    # Network buffer optimizations
    echo 256 | sudo tee /proc/sys/net/core/dev_weight > /dev/null
    echo 128 | sudo tee /proc/sys/net/core/netdev_budget > /dev/null
    echo 600 | sudo tee /proc/sys/net/core/netdev_budget_usecs > /dev/null
    
    log_opt "TCP optimizations applied"
    log_opt "BBR congestion control enabled"
    
    log_info "Network optimization complete"
}

# ============================================================================
# GPU Optimizations
# ============================================================================
optimize_gpu() {
    log_step "Optimizing GPU..."
    
    # Detect GPU vendor
    local gpu_vendor=$(lspci | grep -i "vga\|3d\|display" | head -1 | awk '{print $NF}')
    
    case "$gpu_vendor" in
        *NVIDIA*)
            optimize_nvidia
            ;;
        *AMD*|*ATI*|*Radeon*)
            optimize_amd
            ;;
        *Intel*)
            optimize_intel
            ;;
    esac
}

# NVIDIA GPU optimizations
optimize_nvidia() {
    log_opt "Optimizing NVIDIA GPU..."
    
    # Enable persistence mode
    sudo nvidia-smi -pm 1 2>/dev/null || true
    
    # Set power limit
    sudo nvidia-smi -pl 300 2>/dev/null || true
    
    # Enable coolbits
    sudo nvidia-xconfig --cool-bits=28 2>/dev/null || true
    
    # Set GPU clock
    sudo nvidia-smi -ac 5001,1800 2>/dev/null || true
    
    # Enable G-Sync
    sudo nvidia-settings --assign CurrentMetaMode="nvidia-auto-select +0+0 {ForceFullCompositionPipeline=On}" 2>/dev/null || true
    
    log_opt "NVIDIA GPU optimized"
}

# AMD GPU optimizations
optimize_amd_gpu() {
    log_opt "Optimizing AMD GPU..."
    
    # Enable AMDGPU power features
    echo "manual" | sudo tee /sys/class/drm/card0/device/power_dpm_force_performance_level > /dev/null 2>/dev/null || true
    
    # Set performance level
    echo "performance" | sudo tee /sys/class/drm/card0/device/power_dpm_force_performance_level > /dev/null 2>/dev/null || true
    
    # Enable AMDGPU driver features
    sudo modprobe amdgpu ppfeaturemask=0xffffffff 2>/dev/null || true
    
    # Set GPU clock
    echo "s 1 1800" | sudo tee /sys/class/drm/card0/device/pp_od_clk_voltage > /dev/null 2>/dev/null || true
    echo "c" | sudo tee /sys/class/drm/card0/device/pp_od_clk_voltage > /dev/null 2>/dev/null || true
    
    log_opt "AMD GPU optimized"
}

# Intel GPU optimizations
optimize_intel_gpu() {
    log_opt "Optimizing Intel GPU..."
    
    # Set Intel GPU to performance mode
    echo "performance" | sudo tee /sys/class/drm/card0/device/power_dpm_force_performance_level > /dev/null 2>/dev/null || true
    
    # Enable Intel GPU features
    sudo modprobe i915 enable_guc=3 2>/dev/null || true
    
    log_opt "Intel GPU optimized"
}

# ============================================================================
# Audio Optimizations
# ============================================================================
optimize_audio() {
    log_step "Optimizing audio..."
    
    # Configure PipeWire for gaming
    mkdir -p ~/.config/pipewire/pipewire.conf.d
    
    cat > ~/.config/pipewire/pipewire.conf.d/99-gaming.conf << 'EOF'
# Moon OS Gaming Audio Configuration
# Optimized for low latency

context.properties = {
    default.clock.rate = 48000
    default.clock.quantum = 64
    default.clock.min-quantum = 32
    default.clock.max-quantum = 2048
}

context.modules = [
    { name = libpipewire-module-rt
      args = {
          nice.level = -11
          rt.prio = 88
          rt.time.soft = -1
          rt.time.hard = -1
      }
      flags = [ ifexists nofail ]
    }
]
EOF
    
    # Configure WirePlumber
    mkdir -p ~/.config/wireplumber/main.lua.d
    
    cat > ~/.config/wireplumber/main.lua.d/51-gaming-config.lua << 'EOF'
-- Moon OS Gaming Audio Configuration

rule = {
  matches = {
    {
      { "media.class", "equals", "Audio/Sink" },
    },
  },
  apply_properties = {
    ["audio.format"] = "S32LE",
    ["audio.rate"] = 48000,
    ["audio.channels"] = 2,
    ["api.alsa.period-size"] = 256,
    ["api.alsa.period-num"] = 2,
    ["api.alsa.headroom"] = 1024,
  },
}

table.insert(alsa_monitor.rules, rule)
EOF
    
    # Set audio limits
    sudo mkdir -p /etc/security/limits.d
    cat > /tmp/99-audio.conf << 'EOF'
@audio - rtprio 95
@audio - memlock unlimited
@audio - nice -10
EOF
    sudo mv /tmp/99-audio.conf /etc/security/limits.d/
    
    # Restart PipeWire
    systemctl --user restart pipewire 2>/dev/null || true
    systemctl --user restart pipewire-pulse 2>/dev/null || true
    systemctl --user restart wireplumber 2>/dev/null || true
    
    log_opt "PipeWire configured for gaming"
    log_opt "Low latency audio enabled"
    
    log_info "Audio optimization complete"
}

# ============================================================================
# Display Optimizations
# ============================================================================
optimize_display() {
    log_step "Optimizing display..."
    
    # Configure environment variables
    sudo mkdir -p /etc/environment.d
    
    cat > /tmp/10-display.conf << 'EOF'
# Moon OS Display Optimizations
MOZ_ENABLE_WAYLAND=1
GDK_BACKEND=wayland,x11
QT_QPA_PLATFORM=wayland;xcb
SDL_VIDEODRIVER=wayland
CLUTTER_BACKEND=wayland
XDG_SESSION_TYPE=wayland
WLR_NO_HARDWARE_CURSORS=1
GBM_BACKEND=nvidia-drm
__GLX_VENDOR_LIBRARY_NAME=nvidia
EOF
    sudo mv /tmp/10-display.conf /etc/environment.d/10-display.conf
    
    # Configure X11 optimizations
    sudo mkdir -p /etc/X11/xorg.conf.d
    cat > /tmp/10-x11.conf << 'EOF'
Section "Device"
    Identifier "Default Device"
    Option "AccelMethod" "glamor"
    Option "DRI" "3"
    Option "TearFree" "true"
    Option "TripleBuffer" "true"
    Option "SwapbuffersWait" "false"
    Option "AccelProfileScaling" "true"
EndSection

Section "Screen"
    Identifier "Default Screen"
    Option "AllowIndirectGLXProtocol" "off"
