# ============================================================================
# System Services Optimizations
# ============================================================================
optimize_services() {
    log_step "Optimizing system services..."
    
    # Disable unnecessary services
    local disable_services=(
        "cups"
        "bluetooth"
        "ModemManager"
        "avahi-daemon"
        "accounts-daemon"
        "colord"
        "rtkit-daemon"
        "firewalld"
    )
    
    for service in "${disable_services[@]}"; do
        if systemctl is-enabled "$service" 2>/dev/null; then
            sudo systemctl disable "$service" 2>/dev/null || true
            log_opt "Disabled: $service"
        fi
    done
    
    # Enable gaming services
    local enable_services=(
        "NetworkManager"
        "pipewire"
        "pipewire-pulse"
        "wireplumber"
        "gamemoded"
    )
    
    for service in "${enable_services[@]}"; do
        if systemctl list-unit-files | grep -q "^${service}"; then
            sudo systemctl enable "$service" 2>/dev/null || true
            log_opt "Enabled: $service"
        fi
    done
    
    log_info "Service optimization complete"
}

# ============================================================================
# Security Optimizations
# ============================================================================
optimize_security() {
    log_step "Optimizing security..."
    
    # Configure security settings
    sudo cat > /etc/sysctl.d/99-security.conf << 'EOF'
# Moon OS Security Optimizations

# Network security
net.ipv4.conf.all.rp_filter=1
net.ipv4.conf.default.rp_filter=1
net.ipv4.icmp_echo_ignore_broadcasts=1
net.ipv4.conf.all.accept_redirects=0
net.ipv4.conf.default.accept_redirects=0
net.ipv4.conf.all.secure_redirects=0
net.ipv4.conf.default.secure_redirects=0
net.ipv4.conf.all.send_redirects=0
net.ipv4.conf.default.send_redirects=0
net.ipv4.conf.all.accept_source_route=0
net.ipv4.conf.default.accept_source_route=0
net.ipv4.tcp_syncookies=1
net.ipv4.tcp_synack_retries=2
net.ipv4.tcp_syn_retries=5

# IPv6
net.ipv6.conf.all.accept_redirects=0
net.ipv6.conf.default.accept_redirects=0
net.ipv6.conf.all.accept_source_route=0
net.ipv6.conf.default.accept_source_route=0

# Kernel security
kernel.kptr_restrict=2
kernel.yama.ptrace_scope=1
kernel.dmesg_restrict=1
kernel.perf_event_paranoid=3
kernel.unprivileged_bpf_disabled=1
net.core.bpf_jit_harden=2
kernel.unprivileged_userns_clone=1
kernel.randomize_va_space=2
fs.suid_dumpable=0
EOF
    
    # Configure firewall
    sudo pacman -S --needed --noconfirm firewalld 2>/dev/null || true
    sudo systemctl enable firewalld 2>/dev/null || true
    
    log_opt "Security hardening applied"
    log_opt "Firewall enabled"
    
    log_info "Security optimization complete"
}

# ============================================================================
# Generate Performance Report
# ============================================================================
generate_report() {
    log_step "Generating performance report..."
    
    local report="/tmp/moon-performance-report.txt"
    
    cat > "$report" << EOF
Moon OS Performance Report
==========================
Generated: $(date)

CPU Information:
$(lscpu | grep -E "^(Architecture|CPU\(s\)|Vendor|Model|Thread|Core|Socket|MHz|Cache)")

Memory Information:
$(free -h)

Storage Information:
$(lsblk -d -o NAME,SIZE,TYPE,ROTA)

GPU Information:
$(lspci | grep -E "VGA|3D|Display")

Network Information:
$(ip link show | grep -E "^[0-9]+")

Audio Information:
$(aplay -l 2>/dev/null || echo "No audio devices")

Display Information:
$(xrandr 2>/dev/null | head -20 || echo "No display detected")

Power Information:
$(cpupower frequency-info 2>/dev/null || echo "No CPU power info")

Gaming Controllers:
$(ls /dev/input/js* 2>/dev/null || echo "No controllers detected")
EOF
    
    log_info "Performance report saved to: $report"
}

# ============================================================================
# Main Function
# ============================================================================
main() {
    echo "=========================================="
    echo "  Moon OS Performance Optimization"
    echo "  Version: $MOON_PERF_VERSION"
    echo "=========================================="
    echo ""
    
    optimize_cpu
    optimize_memory
    optimize_io
    optimize_network
    optimize_gpu
    optimize_audio
    optimize_display
    optimize_power
    optimize_gaming
    optimize_services
    optimize_security
    
    generate_report
    
    echo ""
    echo "=========================================="
    echo "  Optimization Complete!"
    echo "=========================================="
    echo ""
    log_info "All performance optimizations applied!"
    log_info "A performance report has been saved to /tmp/moon-performance-report.txt"
    log_info "Please reboot your system for all changes to take effect."
    echo ""
    echo "To apply optimizations manually, run:"
    echo "  sudo /opt/moonperf/optimize.sh"
    echo ""
}

# Run main function
main "$@"
