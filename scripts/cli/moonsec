# ============================================================================
# Secure DNS
# ============================================================================
setup_secure_dns() {
    log_step "Setting up secure DNS..."
    
    # Install DNS over TLS/HTTPS
    sudo pacman -S --needed --noconfirm \
        systemd-resolved \
        2>/dev/null || true
    
    # Enable systemd-resolved
    sudo systemctl enable systemd-resolved
    
    # Configure secure DNS
    sudo cat > /etc/systemd/resolved.conf << 'EOF'
[Resolve]
# Moon OS Secure DNS Configuration

# DNS servers with DNSSEC support
DNS=1.1.1.1#cloudflare-dns.com 9.9.9.9#dns.quad9.net 8.8.8.8#dns.google
FallbackDNS=1.0.0.1#cloudflare-dns.com 149.112.112.112#dns.quad9.net

# Enable DNSSEC
DNSSEC=yes

# Enable DNS over TLS
DNSOverTLS=yes

# DNS cache size
CacheSize=10000

# Enable additional DNS features
MulticastDNS=yes
LLMNR=yes
ResolveUnicastSingleLabel=yes
EOF
    
    # Create DNSSEC trust anchor
    sudo mkdir -p /etc/dnssec-trust-anchors.d
    
    # Configure DNSSEC negative trust anchors
    sudo cat > /etc/dnssec-trust-anchors.d/negative.ans \
        > /dev/null 2>&1 || true
    
    log_info "Secure DNS configured"
}

