# AppArmor Configuration
setup_apparmor() {
    log_step "Setting up AppArmor..."
    
    # Install AppArmor
    sudo pacman -S --needed --noconfirm \
        apparmor \
        apparmor-utils \
        apparmor-profiles \
        apparmor-tools \
        2>/dev/null || true
    
    # Enable AppArmor service
    sudo systemctl enable apparmor
    
    # Configure AppArmor
    sudo mkdir -p /etc/apparmor.d
    
    # Create base profiles
    create_apparmor_profiles
    
    # Set AppArmor to enforce mode
    sudo aa-enforce /etc/apparmor.d/* 2>/dev/null || true
    
    log_info "AppArmor configured"
}

