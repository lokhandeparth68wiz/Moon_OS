    log_info "Generating package signing keys..."
    
    # Generate GPG key for Moon OS packages
    gpg --batch --gen-key << EOF
%echo Generating Moon OS package signing key
Key-Type: RSA
Key-Length: 4096
Subkey-Type: RSA
Subkey-Length: 4096
Name-Real: Moon OS Package Signing
Name-Email: packages@moonos.dev
