# ============================================================================
# Disk Encryption (LUKS2)
# ============================================================================
setup_disk_encryption() {
    log_step "Setting up disk encryption..."
    
    # Install LUKS tools
    sudo pacman -S --needed --noconfirm \
        cryptsetup \
        cryptsetup-nuke-keys \
        2>/dev/null || true
    
    log_info "Disk encryption tools installed"
}

# Encrypt partition
encrypt_partition() {
    local device="$1"
    local passphrase="$2"
    
    log_info "Encrypting partition: $device"
    
    # Create LUKS2 partition
    echo -n "$passphrase" | sudo cryptsetup luksFormat \
        --type luks2 \
        --cipher aes-xts-plain64 \
        --key-size 512 \
        --hash sha512 \
        --iter-time 5000 \
        --verify-passphrase \
        "$device" -
    
    # Open encrypted partition
    echo -n "$passphrase" | sudo cryptsetup open "$device" moonos-encrypted -
    
    # Create filesystem
    sudo mkfs.ext4 -L "moonos" /dev/mapper/moonos-encrypted
    
    log_info "Partition encrypted successfully"
}

# ============================================================================
# TPM Support
# ============================================================================
setup_tpm() {
    log_step "Setting up TPM support..."
    
    # Install TPM tools
    sudo pacman -S --needed --noconfirm \
        tpm2-tss \
        tpm2-tools \
        tpm2-abrmd \
        2>/dev/null || true
    
    # Enable TPM services
    sudo systemctl enable tpm2-abrmd 2>/dev/null || true
    
    # Create TPM configuration
    sudo mkdir -p /etc/tpm2
    
    # Configure automatic LUKS unlock with TPM
    sudo cat > /etc/tpm2/tpm2-unlock.conf << 'EOF'
# Moon OS TPM Unlock Configuration
# Automatically unlock LUKS with TPM

# Enable TPM-based unlock
ENABLE_TPM_UNLOCK=true

# TPM device
TPM_DEVICE=/dev/tpm0

# PCR banks to seal against
PCR_BANKS=sha256

# PCR selections (secure boot, boot loader, kernel)
PCR_SELECTIONS=0,1,2,3,4,5,7

# Auto-unlock delay (seconds)
UNLOCK_DELAY=5
EOF
    
    log_info "TPM support configured"
}

# Seal LUKS key to TPM
seal_key_to_tpm() {
    local device="$1"
    
    log_info "Sealing LUKS key to TPM..."
    
    # Get LUKS UUID
    local uuid=$(sudo cryptsetup luksUUID "$device")
    
    # Create TPM PCR policy
    sudo systemd-cryptenroll \
        --tpm2-device=auto \
        --tpm2-pcrs=0+1+2+3+4+5+7 \
        "$device"
    
    log_info "Key sealed to TPM"
}

# ============================================================================
# Secure Boot
# ============================================================================
setup_secure_boot() {
    log_step "Setting up Secure Boot..."
    
    # Install Secure Boot tools
    sudo pacman -S --needed --noconfirm \
        shim \
        sbsigntools \
        secureboot-hook \
        2>/dev/null || true
    
    # Create Secure Boot configuration
    sudo mkdir -p /etc/secureboot
    
    # Generate Secure Boot keys
    generate_secureboot_keys
    
    # Sign bootloader
    sign_bootloader
    
    # Sign kernel
    sign_kernel
    
    log_info "Secure Boot configured"
}

# Generate Secure Boot keys
generate_secureboot_keys() {
    log_info "Generating Secure Boot keys..."
    
    local keydir="/etc/secureboot/keys"
    sudo mkdir -p "$keydir"
    
    # Generate Platform Key (PK)
    sudo openssl req -new -x509 \
        -newkey rsa:4096 \
        -keyout "$keydir/PK.key" \
        -out "$keydir/PK.crt" \
        -days 3650 \
        -nodes \
        -subj "/CN=Moon OS Platform Key/"
    
    # Generate Key Exchange Key (KEK)
    sudo openssl req -new -x509 \
        -newkey rsa:4096 \
        -keyout "$keydir/KEK.key" \
        -out "$keydir/KEK.crt" \
        -days 3650 \
        -nodes \
        -subj "/CN=Moon OS Key Exchange Key/"
    
    # Generate Signature Database key (db)
    sudo openssl req -new -x509 \
        -newkey rsa:4096 \
        -keyout "$keydir/db.key" \
        -out "$keydir/db.crt" \
        -days 3650 \
        -nodes \
        -subj "/CN=Moon OS Signature Database/"
    
    # Create GUID for keys
    sudo python3 -c "import uuid; print(uuid.uuid4())" | sudo tee "$keydir/GUID" > /dev/null
    
    # Convert to authenticated variables
    sudo cert-to-efi-sig-list -g "$(cat "$keydir/GUID")" \
        -k "$keydir/PK.key" \
        -c "$keydir/PK.crt" \
        "$keydir/PK.esl"
    
    sudo cert-to-efi-sig-list -g "$(cat "$keydir/GUID")" \
        -k "$keydir/KEK.key" \
        -c "$keydir/KEK.crt" \
        "$keydir/KEK.esl"
    
    sudo cert-to-efi-sig-list -g "$(cat "$keydir/GUID")" \
        -k "$keydir/db.key" \
        -c "$keydir/db.crt" \
        "$keydir/db.esl"
    
    # Sign the authenticated variable lists
    sudo sign-efi-sig-list -g "$(cat "$keydir/GUID")" \
        -k "$keydir/PK.key" \
        -c "$keydir/PK.crt" \
        PK "$keydir/PK.esl" \
        "$keydir/PK.auth"
    
    sudo sign-efi-sig-list -g "$(cat "$keydir/GUID")" \
        -k "$keydir/PK.key" \
        -c "$keydir/PK.crt" \
        KEK "$keydir/KEK.esl" \
        "$keydir/KEK.auth"
    
    sudo sign-efi-sig-list -g "$(cat "$keydir/GUID")" \
        -k "$keydir/KEK.key" \
        -c "$keydir/KEK.crt" \
        db "$keydir/db.esl" \
        "$keydir/db.auth"
    
    log_info "Secure Boot keys generated"
}

# Sign bootloader
sign_bootloader() {
    log_info "Signing bootloader..."
    
    local keydir="/etc/secureboot/keys"
    
    # Sign GRUB
    sudo sbsign \
        --key "$keydir/db.key" \
        --cert "$keydir/db.crt" \
        --output /boot/efi/EFI/moonos/grubx64.efi.signed \
        /boot/efi/EFI/moonos/grubx64.efi
    
    # Replace unsigned with signed
    sudo mv /boot/efi/EFI/moonos/grubx64.efi.signed \
        /boot/efi/EFI/moonos/grubx64.efi
    
    log_info "Bootloader signed"
}

# Sign kernel
sign_kernel() {
    log_info "Signing kernel..."
    
    local keydir="/etc/secureboot/keys"
    local kernel="/boot/vmlinuz-linux"
    
    # Sign kernel
    sudo sbsign \
        --key "$keydir/db.key" \
        --cert "$keydir/db.crt" \
        --output "${kernel}.signed" \
        "$kernel"
    
    # Replace unsigned with signed
    sudo mv "${kernel}.signed" "$kernel"
    
    log_info "Kernel signed"
}

# ============================================================================
# Firewall
# ============================================================================
setup_firewall() {
    log_step "Setting up firewall..."
    
    # Install firewall
    sudo pacman -S --needed --noconfirm \
        nftables \
        2>/dev/null || true
    
    # Create firewall rules
    create_firewall_rules
    
    # Enable firewall
    sudo systemctl enable nftables
    
    log_info "Firewall configured"
}

# Create comprehensive firewall rules
create_firewall_rules() {
    log_info "Creating firewall rules..."
    
    sudo cat > /etc/nftables.conf << 'EOF'
#!/usr/sbin/nft -f

# Moon OS Firewall Configuration
# Gaming-optimized with security hardening

flush ruleset

# Define variables
define LAN_IF = en*
define WAN_IF = en*
define WIRELESS_IF = wl*
define VPN_IF = tun*
define GAMESERVER_PORTS = 27015-27050,3478-4380,27000-27100,1935,3478-3479,3480
define VPN_PORTS = 500,4500
define SSH_PORT = 22

# Create tables
table inet filter {
    # Input chain
    chain input {
        type filter hook input priority filter; policy drop;
        
        # Allow established/related connections
        ct state established,related accept
        
        # Drop invalid connections
        ct state invalid drop
        
        # Allow loopback
        iif "lo" accept
        
        # Allow ICMP (rate limited)
        ip protocol icmp limit rate 4/second accept
        ip6 nexthdr icmpv6 limit rate 4/second accept
        
        # Allow SSH (rate limited)
        tcp dport $SSH_PORT ct state new limit rate 3/minute accept
        
        # Allow gaming ports
        tcp dport $GAMESERVER_PORTS accept
        udp dport $GAMESERVER_PORTS accept
        
        # Allow VPN
        udp dport $VPN_PORTS accept
        iifname $VPN_IF accept
        
        # Allow local network
        iifname $LAN_IF ip saddr 192.168.0.0/16 accept
        iifname $LAN_IF ip saddr 10.0.0.0/8 accept
        iifname $LAN_IF ip saddr 172.16.0.0/12 accept
        
        # Allow mDNS (local network discovery)
        udp dport 5353 accept
        
        # Log and drop everything else
        log prefix "[nft-drop] " limit rate 5/minute drop
    }
    
    # Forward chain
    chain forward {
        type filter hook forward priority filter; policy drop;
        
        # Allow established/related
        ct state established,related accept
        
        # Drop invalid
        ct state invalid drop
        
        # Allow VPN forwarding
        iifname $VPN_IF accept
        oifname $VPN_IF accept
        
        # Allow Docker/containers
        iifname docker0 accept
        oifname docker0 accept
        iifname br-* accept
        oifname br-* accept
    }
    
    # Output chain
    chain output {
        type filter hook output priority filter; policy accept;
        
        # Allow all outgoing (restrict in privacy section)
        accept
    }
}

# NAT table for VPN/Docker
table ip nat {
    chain postrouting {
        type nat hook postrouting priority srcnat;
        
        # Masquerade VPN traffic
        oifname $VPN_IF masquerade
        
        # Masquerade Docker traffic
        oifname docker0 masquerade
        oifname br-* masquerade
    }
}

# Connection tracking
table inet ct {
    chain new {
        type filter hook output priority -100; policy accept;
        
        # Track new connections
        ct state new accept
    }
}
EOF
    
    log_info "Firewall rules created"
}

# ============================================================================
# Network Security
# ============================================================================
setup_network_security() {
    log_step "Setting up network security..."
    
    # Enable kernel network security
    sudo cat > /etc/sysctl.d/99-network-security.conf << 'EOF'
# Moon OS Network Security Hardening

# Disable IP forwarding (unless VPN/Docker)
net.ipv4.ip_forward=0
net.ipv6.conf.all.forwarding=0

# Disable ICMP redirects
net.ipv4.conf.all.accept_redirects=0
net.ipv4.conf.default.accept_redirects=0
net.ipv4.conf.all.send_redirects=0
net.ipv4.conf.default.send_redirects=0
net.ipv6.conf.all.accept_redirects=0
net.ipv6.conf.default.accept_redirects=0

# Disable source routing
net.ipv4.conf.all.accept_source_route=0
net.ipv4.conf.default.accept_source_route=0
net.ipv6.conf.all.accept_source_route=0
net.ipv6.conf.default.accept_source_route=0

# Enable SYN flood protection
net.ipv4.tcp_syncookies=1
net.ipv4.tcp_max_syn_backlog=4096
net.ipv4.tcp_synack_retries=2
net.ipv4.tcp_syn_retries=5

# Enable reverse path filtering
net.ipv4.conf.all.rp_filter=1
net.ipv4.conf.default.rp_filter=1

# Log Martian packets
net.ipv4.conf.all.log_martians=1
net.ipv4.conf.default.log_martians=1

# Disable ICMP broadcast replies
net.ipv4.icmp_echo_ignore_broadcasts=1

# Ignore bogus ICMP errors
net.ipv4.icmp_ignore_bogus_error_responses=1

# Enable TCP timestamps (for security)
net.ipv4.tcp_timestamps=1

# Enable TCP SACK
net.ipv4.tcp_sack=1

# Disable IPv6 if not needed
# net.ipv6.conf.all.disable_ipv6=1
# net.ipv6.conf.default.disable_ipv6=1

# Randomize address space layout
kernel.randomize_va_space=2

# Restrict dmesg access
kernel.dmesg_restrict=1

# Restrict kernel pointer access
kernel.kptr_restrict=2

# Restrict perf events
kernel.perf_event_paranoid=3

# Restrict unprivileged user namespaces
kernel.unprivileged_userns_clone=0

# Disable BPF for unprivileged users
kernel.unprivileged_bpf_disabled=1

# Harden BPF JIT
net.core.bpf_jit_harden=2
EOF
    
    log_info "Network security configured"
}

