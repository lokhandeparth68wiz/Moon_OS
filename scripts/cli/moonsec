# Disable telemetry
disable_telemetry() {
    log_info "Disabling telemetry..."
    
    # Disable systemd telemetry
    sudo mkdir -p /etc/systemd/system.conf.d
    sudo cat > /etc/systemd/system.conf.d/telemetry.conf << 'EOF'
[Manager]
# Disable telemetry
LogTarget=journal
    
[Service]
ExecStart=
ExecStart=/usr/lib/systemd/systemd --no-pager
EOF
    
    # Disable GNOME telemetry
    sudo mkdir -p /etc/dconf/db/local.d
    sudo cat > /etc/dconf/db/local.d/privacy << 'EOF'
[org/gnome/desktop/privacy]
send-software-usage-stats=false
report-technical-problems=false
EOF
    
    # Disable KDE telemetry
    sudo mkdir -p /etc/xdg/autostart
    sudo cat > /etc/xdg/autostart/disable-telemetry.desktop << 'EOF'
[Desktop Entry]
Type=Application
Name=Disable Telemetry
Exec=/bin/sh -c 'kwriteconfig5 --file kdeglobals --group "KDE" --key "DisableTelemetry" "true"'
Terminal=false
EOF
    
    # Disable macOS-like tracking
    sudo cat > /etc/sysctl.d/99-privacy.conf << 'EOF'
# Moon OS Privacy Hardening

