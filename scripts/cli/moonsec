#!/bin/bash
# Moon OS Secure Deletion Script

set -euo pipefail

if [[ $# -eq 0 ]]; then
    echo "Usage: $0 <file|directory>"
    exit 1
fi

for item in "$@"; do
    if [[ -f "$item" ]]; then
        echo "Securely deleting file: $item"
