# Configure snapshots
configure_snapshots() {
    log_info "Configuring filesystem snapshots..."
    
    # Create Btrfs snapshot configuration
    sudo mkdir -p /etc/snapper
    
    sudo cat > /etc/snapper/configs/root << 'EOF'
# Moon OS Snapshot Configuration

SUBVOLUME="/"
FSTYPE="btrfs"

# Snapshot cleanup
TIMELINE_MIN_AGE="1800"
TIMELINE_LIMIT_HOURLY="5"
TIMELINE_LIMIT_DAILY="7"
TIMELINE_LIMIT_WEEKLY="0"
TIMELINE_LIMIT_MONTHLY="0"
TIMELINE_LIMIT_YEARLY="0"

# Snapshot cleanup algorithm
TIMELINE_CLEANUP="yes"
EOF
    
    # Create snapshot script
    sudo cat > /usr/local/bin/moon-snapshot << 'SCRIPT'
#!/bin/bash
# Moon OS Snapshot Script

set -euo pipefail

ACTION="${1:-create}"
SNAPSHOT_NAME="${2:-moon-$(date +%Y%m%d-%H%M%S)}"

case "$ACTION" in
    create)
        echo "Creating snapshot: $SNAPSHOT_NAME"
        sudo btrfs subvolume snapshot -r / "/$SNAPSHOT_NAME"
        echo "Snapshot created: /$SNAPSHOT_NAME"
        ;;
    list)
        echo "Available snapshots:"
        sudo btrfs subvolume list / | grep "moon-"
        ;;
    rollback)
        if [[ -z "${3:-}" ]]; then
            echo "Usage: $0 rollback <snapshot-name>"
            exit 1
        fi
        echo "Rolling back to: $3"
        sudo btrfs subvolume delete /
        sudo btrfs subvolume snapshot "/$3" /
        echo "Rollback complete. Please reboot."
        ;;
    delete)
        if [[ -z "${3:-}" ]]; then
            echo "Usage: $0 delete <snapshot-name>"
            exit 1
        fi
        echo "Deleting snapshot: $3"
        sudo btrfs subvolume delete "/$3"
        echo "Snapshot deleted"
        ;;
    *)
        echo "Usage: $0 {create|list|rollback|delete} [snapshot-name]"
        exit 1
        ;;
esac
SCRIPT
    sudo chmod +x /usr/local/bin/moon-snapshot
    
    log_info "Snapshots configured"
}

# Configure backup
configure_backup() {
    log_info "Configuring automatic backup..."
    
    # Create backup script
    sudo cat > /usr/local/bin/moon-backup << 'SCRIPT'
#!/bin/bash
# Moon OS Automatic Backup Script

set -euo pipefail

BACKUP_DIR="/var/backups/moonos"
BACKUP_DATE=$(date +%Y%m%d-%H%M%S)
BACKUP_NAME="backup-${BACKUP_DATE}"

# Create backup directory
mkdir -p "$BACKUP_DIR"

# Create backup
echo "Creating backup: $BACKUP_NAME"
sudo btrfs subvolume snapshot -r / "${BACKUP_DIR}/${BACKUP_NAME}"

# Compress backup
echo "Compressing backup..."
sudo tar czf "${BACKUP_DIR}/${BACKUP_NAME}.tar.gz" -C "${BACKUP_DIR}" "${BACKUP_NAME}"

# Remove uncompressed snapshot
sudo btrfs subvolume delete "${BACKUP_DIR}/${BACKUP_NAME}"

# Keep only last 7 backups
cd "$BACKUP_DIR"
ls -t backup-*.tar.gz | tail -n +8 | xargs rm -f 2>/dev/null || true

echo "Backup complete: ${BACKUP_DIR}/${BACKUP_NAME}.tar.gz"
SCRIPT
    sudo chmod +x /usr/local/bin/moon-backup
    
    # Create systemd timer for automatic backups
    sudo cat > /etc/systemd/system/moon-backup.timer << 'EOF'
[Unit]
Description=Moon OS Automatic Backup

[Timer]
OnCalendar=daily
Persistent=true

[Install]
WantedBy=timers.target
EOF
    
    sudo cat > /etc/systemd/system/moon-backup.service << 'EOF'
[Unit]
Description=Moon OS Backup Service
After=network.target

[Service]
Type=oneshot
ExecStart=/usr/local/bin/moon-backup
User=root
EOF
    
    sudo systemctl enable moon-backup.timer
    
    log_info "Automatic backup configured"
}

