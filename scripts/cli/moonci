# ============================================================================
# Build System
# ============================================================================
setup_build_system() {
    log_step "Setting up build system..."
    
    # Create Makefile
    cat > Makefile << 'EOF'
# Moon OS Build System
# GitHub-first, reproducible builds

MOON_OS_VERSION := $(shell cat VERSION 2>/dev/null || echo "1.0.0")
MOON_OS_CODENAME := $(shell cat VERSION 2>/dev/null | grep CODENAME | cut -d= -f2 || echo "Apex")
TARGET := x86_64
DESKTOP := cosmic
PROFILE := gaming
JOBS := $(shell nproc)

.PHONY: all clean test build iso release

all: build

# ============================================================================
# Build Commands
# ============================================================================

build: build-kernel build-packages build-desktop build-gaming build-security

build-kernel:
	@echo "Building kernel for $(TARGET)..."
	./moonpkg build kernel --target=$(TARGET) --jobs=$(JOBS)

build-packages:
	@echo "Building packages for $(TARGET)..."
	./moonpkg build packages --target=$(TARGET) --profile=$(PROFILE) --jobs=$(JOBS)

build-desktop:
	@echo "Building desktop $(DESKTOP)..."
	./moonpkg build desktop --desktop=$(DESKTOP) --jobs=$(JOBS)

build-gaming:
	@echo "Building gaming stack..."
	./moongame setup

build-security:
	@echo "Building security stack..."
	./moonsec setup

# ============================================================================
# Test Commands
# ============================================================================

test: test-unit test-integration test-security test-gaming

test-unit:
	@echo "Running unit tests..."
	./tests/run.sh --suite=unit

test-integration:
	@echo "Running integration tests..."
	./tests/run.sh --suite=integration

test-security:
	@echo "Running security tests..."
	./tests/run.sh --suite=security

test-gaming:
	@echo "Running gaming tests..."
	./tests/run.sh --suite=gaming

test-all:
	@echo "Running all tests..."
	./tests/run.sh --all

# ============================================================================
# ISO Commands
# ============================================================================

iso: generate-iso

generate-iso:
	@echo "Generating ISO for $(TARGET) with $(DESKTOP)..."
	./moonpkg iso --target=$(TARGET) --desktop=$(DESKTOP) --output=moonos-$(MOON_OS_VERSION)-$(TARGET)-$(DESKTOP).iso

# ============================================================================
# Release Commands
# ============================================================================

release: release-prepare release-tag release-publish

release-prepare:
	@echo "Preparing release..."
	./moonci release prepare --version=$(MOON_OS_VERSION)

release-tag:
	@echo "Tagging release..."
