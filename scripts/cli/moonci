# ============================================================================
# Version Management
# ============================================================================
bump_version() {
    local part="${1:-patch}"
    
    log_step "Bumping version ($part)..."
    
    # Read current version
    local current=$(cat VERSION 2>/dev/null | head -1 | cut -d= -f2 || echo "1.0.0")
    local major=$(echo "$current" | cut -d. -f1)
    local minor=$(echo "$current" | cut -d. -f2)
    local patch=$(echo "$current" | cut -d. -f3)
    
    # Bump version
    case "$part" in
        major)
            major=$((major + 1))
            minor=0
            patch=0
            ;;
        minor)
            minor=$((minor + 1))
            patch=0
            ;;
        patch)
            patch=$((patch + 1))
            ;;
        *)
            log_error "Invalid version part: $part"
            exit 1
            ;;
    esac
    
    local new_version="$major.$minor.$patch"
    
    # Update VERSION file
    cat > VERSION << EOF
MOON_OS_VERSION="$new_version"
MOON_OS_CODENAME="Apex"
MOON_OS_KERNEL="6.12.5-moon"
MOON_OS_GLIBC="2.40"
MOON_OS_GCC="14.2.0"
MOON_OS_CLANG="19.1.0"
MOON_OS_MESA="24.3.1"
MOON_OS_VULKAN="1.3.296"
MOON_OS_PROTON="9.0-4"
MOON_OS_STEAM="1.0.0.81"
MOON_OS_GNOME="47.1"
MOON_OS_KDE="6.2.4"
MOON_OS_COSMIC="1.0.0"
MOON_OS_WAYLAND="1.23.0"
MOON_OS_XORG="21.1.14"
MOON_OS_SYSTEMD="256.7"
MOON_OS_PIPEWIRE="1.2.7"
MOON_OS_FIREFOX="133.0"
MOON_OS_CHROMIUM="131.0.6778.85"
EOF
    
    log_info "Version bumped: $current -> $new_version"
}

