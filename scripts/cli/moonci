#!/bin/bash
# MOONCI - Moon OS CI/CD & Release Engineering System
# GitHub-first, fully automated, reproducible, documented

set -euo pipefail

MOON_CI_VERSION="1.0.0"
MOON_CI_ROOT="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"

# Color codes
RED='\033[0;31m'
GREEN='\033[0;32m'
YELLOW='\033[1;33m'
BLUE='\033[0;34m'
MAGENTA='\033[0;35m'
CYAN='\033[0;36m'
NC='\033[0m'

log_info() { echo -e "${GREEN}[INFO]${NC} $1"; }
log_warn() { echo -e "${YELLOW}[WARN]${NC} $1"; }
log_error() { echo -e "${RED}[ERROR]${NC} $1"; }
log_step() { echo -e "${BLUE}[STEP]${NC} $1"; }
log_ci() { echo -e "${MAGENTA}[CI]${NC} $1"; }

# ============================================================================
# Git Repository Setup
# ============================================================================
setup_git_repository() {
    log_step "Setting up Git repository..."
    
    # Initialize Git repository
    if [[ ! -d .git ]]; then
        git init
        git branch -M main
    fi
    
    # Create .gitignore
    cat > .gitignore << 'EOF'
# Build artifacts
build/
output/
sysroot/
toolchain/

# Package cache
cache/
*.tar.*
*.pkg.*

# Editor files
.vscode/
.idea/
*.swp
*.swo
*~

# OS files
.DS_Store
Thumbs.db
desktop.ini

# Logs
*.log
logs/

# Temporary files
*.tmp
*.temp
*.bak

# Secrets (NEVER commit)
.env
*.key
*.pem
*.secret
secrets/

# Coverage reports
coverage/
*.gcov
*.gcno
*.gcda
EOF
    
    # Create .gitattributes
    cat > .gitattributes << 'EOF'
# Auto detect text files and perform LF normalization
* text=auto

# Shell scripts
*.sh text eol=lf
*.bash text eol=lf

# Python
*.py text eol=lf

# YAML
*.yml text eol=lf
*.yaml text eol=lf

# Markdown
*.md text eol=lf

# Config files
*.conf text eol=lf
*.cfg text eol=lf
*.ini text eol=lf

# Binary files
*.png binary
*.jpg binary
*.jpeg binary
*.gif binary
*.ico binary
*.pdf binary
*.zip binary
*.tar.* binary
*.iso binary
*.img binary

# LFS
*.iso filter=lfs diff=lfs merge=lfs -text
*.img filter=lfs diff=lfs merge=lfs -text
*.tar.gz filter=lfs diff=lfs merge=lfs -text
*.tar.xz filter=lfs diff=lfs merge=lfs -text
*.tar.bz2 filter=lfs diff=lfs merge=lfs -text
EOF
    
    # Create commit hooks
    mkdir -p .git/hooks
    
    cat > .git/hooks/pre-commit << 'HOOK'
#!/bin/bash
# Moon OS Pre-commit Hook
# Ensures every commit compiles

set -euo pipefail

echo "Running pre-commit checks..."

# Check for syntax errors in shell scripts
echo "Checking shell scripts..."
find . -name "*.sh" -o -name "*.bash" | while read -r file; do
    if ! bash -n "$file" 2>/dev/null; then
        echo "Syntax error in: $file"
        exit 1
    fi
done

# Check for syntax errors in Python
echo "Checking Python files..."
find . -name "*.py" | while read -r file; do
    if ! python3 -m py_compile "$file" 2>/dev/null; then
        echo "Syntax error in: $file"
        exit 1
    fi
done

# Check for syntax errors in YAML
echo "Checking YAML files..."
find . -name "*.yml" -o -name "*.yaml" | while read -r file; do
    if ! python3 -c "import yaml; yaml.safe_load(open('$file'))" 2>/dev/null; then
        echo "Syntax error in: $file"
        exit 1
    fi
done

# Check for TODO/FIXME/HACK
echo "Checking for TODO/FIXME/HACK..."
if grep -r "TODO\|FIXME\|HACK" --include="*.sh" --include="*.py" --include="*.yaml" . 2>/dev/null; then
    echo "Warning: Found TODO/FIXME/HACK comments"
    read -p "Continue? (y/N) " -n 1 -r
    echo
    if [[ ! $REPLY =~ ^[Yy]$ ]]; then
        exit 1
    fi
fi

# Run tests
echo "Running tests..."
if [[ -d "tests" ]]; then
    ./tests/run.sh || exit 1
fi

echo "Pre-commit checks passed!"
HOOK
    chmod +x .git/hooks/pre-commit
    
    cat > .git/hooks/commit-msg << 'HOOK'
#!/bin/bash
# Moon OS Commit Message Hook
# Enforces conventional commits

set -euo pipefail

commit_msg=$(cat "$1")

# Conventional commit pattern
pattern="^(feat|fix|docs|style|refactor|perf|test|build|ci|chore|revert)(\(.+\))?: .{1,72}"

if ! echo "$commit_msg" | grep -qE "$pattern"; then
    echo "Error: Commit message does not follow conventional commits format"
    echo ""
    echo "Expected format: <type>(<scope>): <description>"
    echo ""
    echo "Types:"
    echo "  feat:     A new feature"
    echo "  fix:      A bug fix"
    echo "  docs:     Documentation only changes"
    echo "  style:    Code style changes (formatting, missing semi-colons, etc)"
    echo "  refactor: A code change that neither fixes a bug nor adds a feature"
    echo "  perf:     A code change that improves performance"
    echo "  test:     Adding missing tests"
    echo "  build:    Changes that affect the build system"
    echo "  ci:       Changes to CI configuration files"
    echo "  chore:    Other changes that don't modify src or test files"
    echo "  revert:   Reverts a previous commit"
    echo ""
    echo "Examples:"
    echo "  feat(gaming): add automatic GameMode activation"
    echo "  fix(kernel): resolve memory leak in scheduler"
    echo "  docs(installation): update installation guide"
    echo ""
    echo "Your message: $commit_msg"
    exit 1
fi

# Check description length
description=$(echo "$commit_msg" | sed 's/^[^:]*: //')
if [[ ${#description} -gt 72 ]]; then
    echo "Warning: Commit description is longer than 72 characters"
    echo "Description: $description"
fi

echo "Commit message format is valid!"
HOOK
    chmod +x .git/hooks/commit-msg
    
    cat > .git/hooks/pre-push << 'HOOK'
#!/bin/bash
# Moon OS Pre-push Hook
# Ensures code compiles before push

set -euo pipefail

echo "Running pre-push checks..."

# Run full test suite
echo "Running test suite..."
if [[ -d "tests" ]]; then
    ./tests/run.sh || exit 1
fi

# Build packages
echo "Building packages..."
if [[ -f "Makefile" ]]; then
    make build || exit 1
fi

echo "Pre-push checks passed!"
HOOK
    chmod +x .git/hooks/pre-push
    
    log_info "Git repository configured"
}

# ============================================================================
# GitHub Actions CI/CD
# ============================================================================
setup_github_actions() {
    log_step "Setting up GitHub Actions CI/CD..."
    
    mkdir -p .github/workflows
    mkdir -p .github/actions
    mkdir -p .github/ISSUE_TEMPLATE
    mkdir -p .github/PULL_REQUEST_TEMPLATE
    
    # Main CI/CD Pipeline
    cat > .github/workflows/ci.yml << 'EOF'
# Moon OS CI/CD Pipeline
# GitHub Actions workflow for building, testing, and releasing Moon OS

name: Moon OS CI/CD

on:
  push:
    branches: [main, develop, 'release/*']
  pull_request:
    branches: [main, develop]
  schedule:
    - cron: '0 0 * * 0'  # Weekly build
  workflow_dispatch:
    inputs:
      target:
        description: 'Target architecture'
        required: false
        default: 'x86_64'
        type: choice
        options:
          - x86_64
          - aarch64
          - armv7l
      desktop:
        description: 'Desktop environment'
        required: false
        default: 'cosmic'
        type: choice
        options:
          - cosmic
          - gnome
          - kde
          - hyprland
      profile:
        description: 'Build profile'
        required: false
        default: 'gaming'
        type: choice
        options:
          - minimal
          - base
          - gaming
          - desktop
          - server

env:
  MOON_OS_VERSION: "1.0.0"
  MOON_OS_CODENAME: "Apex"

jobs:
  # ============================================================================
  # Lint & Validation
  # ============================================================================
  lint:
    name: Lint & Validate
    runs-on: ubuntu-latest
    steps:
      - name: Checkout repository
        uses: actions/checkout@v4
        with:
          fetch-depth: 0

      - name: Run shellcheck
        uses: ludeeus/action-shellcheck@master
        with:
          scandir: '.'
          severity: 'warning'
          format: 'tty'

      - name: Run yamllint
        uses: ibiqlik/action-yamllint@v3
        with:
          file_or_dir: '.'
          config_data: |
            extends: default
            rules:
              line-length:
                max: 120
              truthy:
                allowed-values: ['true', 'false', 'yes', 'no']

      - name: Validate package definitions
        run: |
          echo "Validating package definitions..."
          for pkg in packages/*/PKGBUILD; do
            if [[ -f "$pkg" ]]; then
              echo "Validating $pkg..."
              bash -n "$pkg"
            fi
          done

      - name: Validate YAML files
        run: |
          echo "Validating YAML files..."
          find . -name "*.yml" -o -name "*.yaml" | while read -r file; do
            echo "Validating $file..."
            python3 -c "import yaml; yaml.safe_load(open('$file'))"
          done

      - name: Check for secrets
        run: |
          echo "Checking for secrets..."
          if grep -r "password\|secret\|api_key\|token" --include="*.sh" --include="*.py" --include="*.yaml" . 2>/dev/null | grep -v ".github/workflows" | grep -v "test"; then
            echo "Warning: Potential secrets found"
            exit 1
          fi

  # ============================================================================
  # Build Packages
  # ============================================================================
  build-packages:
    name: Build Packages
    runs-on: ubuntu-latest
    needs: [lint]
    strategy:
      matrix:
        target: [x86_64, aarch64]
        profile: [minimal, gaming, desktop]
    steps:
      - name: Checkout repository
        uses: actions/checkout@v4

      - name: Setup build environment
        run: |
          sudo apt-get update
          sudo apt-get install -y \
            build-essential \
            git \
            curl \
            wget \
            qemu-user-static \
            binfmt-support

      - name: Cache package builds
        uses: actions/cache@v4
        with:
          path: |
            build/
            cache/
          key: ${{ runner.os }}-packages-${{ matrix.target }}-${{ matrix.profile }}-${{ hashFiles('packages/**') }}
          restore-keys: |
            ${{ runner.os }}-packages-${{ matrix.target }}-${{ matrix.profile }}-
            ${{ runner.os }}-packages-${{ matrix.target }}-

      - name: Build packages
        run: |
          chmod +x moonpkg
          ./moonpkg build --target=${{ matrix.target }} --profile=${{ matrix.profile }}

      - name: Upload package artifacts
        uses: actions/upload-artifact@v4
        with:
          name: packages-${{ matrix.target }}-${{ matrix.profile }}
          path: output/
          retention-days: 30

  # ============================================================================
  # Build Kernel
  # ============================================================================
  build-kernel:
    name: Build Kernel
    runs-on: ubuntu-latest
    needs: [lint]
    strategy:
      matrix:
        target: [x86_64, aarch64]
    steps:
      - name: Checkout repository
        uses: actions/checkout@v4

      - name: Cache kernel build
        uses: actions/cache@v4
        with:
          path: |
            build/kernel/
          key: ${{ runner.os }}-kernel-${{ matrix.target }}-${{ hashFiles('packages/kernel/**') }}
          restore-keys: |
            ${{ runner.os }}-kernel-${{ matrix.target }}-

      - name: Build kernel
        run: |
          chmod +x moonpkg
          ./moonpkg build kernel --target=${{ matrix.target }}

      - name: Upload kernel artifact
        uses: actions/upload-artifact@v4
        with:
          name: kernel-${{ matrix.target }}
          path: build/kernel/
          retention-days: 30

  # ============================================================================
  # Build Desktop
  # ============================================================================
  build-desktop:
    name: Build Desktop
    runs-on: ubuntu-latest
    needs: [lint]
    strategy:
      matrix:
        desktop: [cosmic, gnome, kde, hyprland]
    steps:
      - name: Checkout repository
        uses: actions/checkout@v4

      - name: Cache desktop build
        uses: actions/cache@v4
        with:
          path: |
            build/desktop/
          key: ${{ runner.os }}-desktop-${{ matrix.desktop }}-${{ hashFiles('packages/desktop/**') }}
          restore-keys: |
            ${{ runner.os }}-desktop-${{ matrix.desktop }}-

      - name: Build desktop
        run: |
          chmod +x moonpkg
          ./moonpkg build desktop --desktop=${{ matrix.desktop }}

      - name: Upload desktop artifact
        uses: actions/upload-artifact@v4
        with:
          name: desktop-${{ matrix.desktop }}
          path: build/desktop/
          retention-days: 30

  # ============================================================================
  # Build Gaming Stack
  # ============================================================================
  build-gaming:
    name: Build Gaming Stack
    runs-on: ubuntu-latest
    needs: [lint]
    steps:
      - name: Checkout repository
        uses: actions/checkout@v4

      - name: Cache gaming build
        uses: actions/cache@v4
        with:
          path: |
            build/gaming/
          key: ${{ runner.os }}-gaming-${{ hashFiles('packages/gaming/**') }}
          restore-keys: |
            ${{ runner.os }}-gaming-

      - name: Build gaming stack
        run: |
          chmod +x moongame
          ./moongame setup

      - name: Upload gaming artifact
        uses: actions/upload-artifact@v4
        with:
          name: gaming-stack
          path: build/gaming/
          retention-days: 30

  # ============================================================================
  # Build Security
  # ============================================================================
  build-security:
    name: Build Security
    runs-on: ubuntu-latest
    needs: [lint]
    steps:
      - name: Checkout repository
        uses: actions/checkout@v4

      - name: Cache security build
        uses: actions/cache@v4
        with:
          path: |
            build/security/
          key: ${{ runner.os }}-security-${{ hashFiles('packages/security/**') }}
          restore-keys: |
            ${{ runner.os }}-security-

      - name: Build security packages
        run: |
          chmod +x moonsec
          ./moonsec setup

      - name: Upload security artifact
        uses: actions/upload-artifact@v4
        with:
          name: security-stack
          path: build/security/
          retention-days: 30

  # ============================================================================
  # Run Tests
  # ============================================================================
  test:
    name: Test
    runs-on: ubuntu-latest
    needs: [build-packages, build-kernel, build-desktop, build-gaming, build-security]
    strategy:
      matrix:
        test-suite: [unit, integration, security, gaming]
    steps:
      - name: Checkout repository
        uses: actions/checkout@v4

      - name: Download all artifacts
        uses: actions/download-artifact@v4
        with:
          path: artifacts/

      - name: Setup test environment
        run: |
          sudo apt-get update
          sudo apt-get install -y \
            qemu-system-x86 \
            ovmf

      - name: Run tests
        run: |
          chmod +x tests/run.sh
          ./tests/run.sh --suite=${{ matrix.test-suite }}

      - name: Upload test results
        uses: actions/upload-artifact@v4
        if: always()
        with:
          name: test-results-${{ matrix.test-suite }}
          path: test-results/
          retention-days: 30

  # ============================================================================
  # Generate ISO
  # ============================================================================
  generate-iso:
    name: Generate ISO
    runs-on: ubuntu-latest
    needs: [test]
    strategy:
      matrix:
        target: [x86_64, aarch64]
        desktop: [cosmic, gnome]
    steps:
      - name: Checkout repository
        uses: actions/checkout@v4

      - name: Download all artifacts
        uses: actions/download-artifact@v4
        with:
          path: artifacts/

      - name: Setup ISO generation
        run: |
          sudo apt-get update
          sudo apt-get install -y \
            squashfs-tools \
            xorriso \
            grub-pc-bin \
            grub-efi-amd64-bin \
            mtools \
            dosfstools

      - name: Generate ISO
        run: |
          chmod +x moonpkg
          ./moonpkg iso \
            --target=${{ matrix.target }} \
            --desktop=${{ matrix.desktop }} \
            --output=moonos-${{ env.MOON_OS_VERSION }}-${{ matrix.target }}-${{ matrix.desktop }}.iso

      - name: Generate checksums
        run: |
          sha256sum moonos-*.iso > checksums.txt
          sha512sum moonos-*.iso >> checksums.txt

      - name: Upload ISO
        uses: actions/upload-artifact@v4
        with:
          name: iso-${{ matrix.target }}-${{ matrix.desktop }}
          path: |
            moonos-*.iso
            checksums.txt
          retention-days: 30

  # ============================================================================
  # Documentation
  # ============================================================================
  documentation:
    name: Documentation
    runs-on: ubuntu-latest
    needs: [lint]
    steps:
      - name: Checkout repository
        uses: actions/checkout@v4

      - name: Setup documentation
        run: |
          sudo apt-get update
          sudo apt-get install -y \
            python3-sphinx \
            python3-sphinx-rtd-theme \
            markdown

      - name: Build documentation
        run: |
          cd docs
          make html

      - name: Upload documentation
        uses: actions/upload-artifact@v4
        with:
          name: documentation
          path: docs/_build/html/
          retention-days: 30

  # ============================================================================
  # Package Repository
  # ============================================================================
  package-repository:
    name: Package Repository
    runs-on: ubuntu-latest
    needs: [test]
    strategy:
      matrix:
        target: [x86_64, aarch64]
    steps:
      - name: Checkout repository
        uses: actions/checkout@v4

      - name: Download package artifacts
        uses: actions/download-artifact@v4
        with:
          name: packages-${{ matrix.target }}-gaming
          path: packages/

      - name: Generate package repository
        run: |
          chmod +x moonpkg
          ./moonpkg repo --target=${{ matrix.target }}

      - name: Upload repository
        uses: actions/upload-artifact@v4
        with:
          name: repository-${{ matrix.target }}
          path: repository/
          retention-days: 30

  # ============================================================================
  # Release
  # ============================================================================
  release:
    name: Release
    runs-on: ubuntu-latest
    needs: [generate-iso, documentation, package-repository]
    if: github.ref == 'refs/heads/main' && github.event_name == 'push'
    steps:
      - name: Checkout repository
        uses: actions/checkout@v4
        with:
          fetch-depth: 0

      - name: Download all artifacts
        uses: actions/download-artifact@v4
        with:
          path: artifacts/

      - name: Generate changelog
        run: |
          chmod +x moonci
          ./moonci changelog --output=CHANGELOG.md

      - name: Generate release notes
        run: |
          chmod +x moonci
          ./moonci release-notes --output=RELEASE_NOTES.md

      - name: Create GitHub Release
        uses: softprops/action-gh-release@v1
        with:
          tag_name: v${{ env.MOON_OS_VERSION }}
          name: Moon OS ${{ env.MOON_OS_CODENAME }} v${{ env.MOON_OS_VERSION }}
          body_file: RELEASE_NOTES.md
          files: |
            artifacts/iso-x86_64-cosmic/moonos-*.iso
            artifacts/iso-x86_64-gnome/moonos-*.iso
            artifacts/iso-aarch64-cosmic/moonos-*.iso
            artifacts/iso-aarch64-gnome/moonos-*.iso
            artifacts/documentation/
            artifacts/repository-x86_64/
            artifacts/repository-aarch64/
          draft: false
          prerelease: false
        env:
          GITHUB_TOKEN: ${{ secrets.GITHUB_TOKEN }}

      - name: Publish documentation
        uses: peaceiris/actions-gh-pages@v3
        with:
          github_token: ${{ secrets.GITHUB_TOKEN }}
          publish_dir: artifacts/documentation/
          destination_dir: docs

      - name: Sync mirrors
        run: |
          chmod +x moonci
          ./moonci sync-mirrors

  # ============================================================================
  # Mirror Sync
  # ============================================================================
  sync-mirrors:
    name: Sync Mirrors
    runs-on: ubuntu-latest
    needs: [release]
    if: github.ref == 'refs/heads/main' && github.event_name == 'push'
    steps:
      - name: Checkout repository
        uses: actions/checkout@v4

      - name: Sync to mirrors
        run: |
          chmod +x moonci
          ./moonci sync-mirrors
