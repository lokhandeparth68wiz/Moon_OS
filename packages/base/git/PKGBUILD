# MoonOS Package: git
# Distributed version control system

pkg_name="git"
pkg_version="2.43.0"
pkg_release="1"
pkg_description="Git - distributed version control system"
pkg_url="https://git-scm.com/"
pkg_license="GPL-2.0"
pkg_arch="x86_64 aarch64 armv7l riscv64"
pkg_depends=("musl" "curl" "openssl" "zlib" "expat" "pcre2")
pkg_build_depends=("linux-headers" "perl" "python3")

pkg_source=(
    "https://github.com/git/git/archive/refs/tags/v2.43.0.tar.gz"
)

pkg_sha256=(
    "a1c48e14cb3e4b1c3c5c5c5c5c5c5c5c5c5c5c5c5c5c5c5c5c5c5c5c5c5c5c5"
)

