pkg_compile() {
    make -j"$(nproc)"
}

pkg_install() {
    make prefix=/usr \
        sysconfdir=/etc \
        localstatedir=/var \
        DESTDIR="${PKG_INSTALL_DIR}" \
        install
}

pkg_prelude() {
    # Ensure dependencies are installed
    for dep in curl openssl zlib expat pcre2; do
        if ! pkg_is_installed "$dep"; then
            log_info "Building dependency: $dep"
            build_package "$dep"
        fi
    done
}
