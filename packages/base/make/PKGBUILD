# MoonOS Package: make
# GNU Make build tool

pkg_name="make"
pkg_version="4.4.1"
pkg_release="1"
pkg_description="GNU Make - a tool which controls the generation of executables"
pkg_url="https://www.gnu.org/software/make/"
pkg_license="GPL-3.0"
pkg_arch="x86_64 aarch64 armv7l riscv64"
pkg_depends=("musl")
pkg_build_depends=("linux-headers")

pkg_source=(
    "https://ftp.gnu.org/gnu/make/make-4.4.1.tar.gz"
)

pkg_sha256=(
    "ed87230a6da3538aab550fcf641648e50af9286e0a488014f58136c3d8c5d574"
)

pkg_configure() {
    ./configure \
        --prefix=/usr \
        --sysconfdir=/etc \
        --localstatedir=/var \
        --enable-shared \
        --disable-static \
        --disable-nls
}

pkg_compile() {
    make -j"$(nproc)"
}

pkg_check() {
    make check
}

pkg_install() {
    make DESTDIR="${PKG_INSTALL_DIR}" install
}

pkg_prelude() {
    # No special requirements
    true
}
