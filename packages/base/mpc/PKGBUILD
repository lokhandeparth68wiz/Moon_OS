# MoonOS Package: mpc
# GNU MPC Library

pkg_name="mpc"
pkg_version="1.3.1"
pkg_release="1"
pkg_description="GNU MPC Library - complex arithmetic library"
pkg_url="https://www.multiprecision.org/mpc/"
pkg_license="LGPL-3.0"
pkg_arch="x86_64 aarch64 armv7l riscv64"
pkg_depends=("musl" "gmp" "mpfr")
pkg_build_depends=("gmp" "mpfr")

pkg_source=(
    "https://ftp.gnu.org/gnu/mpc/mpc-1.3.1.tar.gz"
)

pkg_sha256=(
    "ab671720426e46aee3e16464c4c4e4e8e0e0e0e0e0e0e0e0e0e0e0e0e0e0e0e0"
)

pkg_configure() {
    ./configure \
        --prefix=/usr \
        --sysconfdir=/etc \
        --localstatedir=/var \
        --libdir=/usr/lib \
        --enable-shared \
        --disable-static \
        --with-gmp=/usr \
        --with-mpfr=/usr
}

pkg_compile() {
    make -j"$(nproc)"
}

pkg_check() {
    make check
}

pkg_install() {
    make DESTDIR="${PKG_INSTALL_DIR}" install
}

pkg_prelude() {
    # Ensure dependencies are installed
    for dep in gmp mpfr; do
        if ! pkg_is_installed "$dep"; then
            log_info "Building dependency: $dep"
            build_package "$dep"
        fi
    done
}
